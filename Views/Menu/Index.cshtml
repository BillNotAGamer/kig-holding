@model MenuGroupLandingViewModel

@{
    ViewData["Title"] = "Thực đơn";
    ViewData["MetaDescription"] = "Khám phá các nhóm thực đơn Truyền Thuyết Champong, Gogimaru và KBB Cook.";

    var groups = Model.Groups;
    var countLabel = groups.Count == 1 ? "1 nhóm thực đơn" : $"{groups.Count} nhóm thực đơn";
}

<section class="menu-hub menu-hub--dark relative overflow-hidden py-20 text-white sm:py-24 lg:py-28" data-menu-page="hub">
    <div class="container-page relative z-10">
        <header class="mx-auto max-w-4xl text-center" data-uw-reveal="fade-up">
            <span class="inline-flex rounded-full border border-brand-red/30 bg-brand-red/10 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.28em] text-red-300">
                THỰC ĐƠN
            </span>
            <h1 class="public-page-title mt-6 text-white">
                Khám phá thực đơn
            </h1>
            <p class="mx-auto mt-5 max-w-2xl text-base leading-8 text-white/70 sm:text-lg">
                Chọn thương hiệu để xem thực đơn chi tiết, hình ảnh món ăn và các lựa chọn phù hợp cho bữa ăn của bạn.
            </p>
            <div class="mt-7 inline-flex items-center rounded-full border border-white/10 bg-white/[0.05] px-4 py-2 text-sm font-semibold text-white/70 backdrop-blur">
                @countLabel
            </div>
        </header>

        @if (groups.Count > 0)
        {
            <div class="mt-14 space-y-7 lg:mt-16 lg:space-y-9">
                @for (var index = 0; index < groups.Count; index++)
                {
                    var group = groups[index];
                    var isReversed = index % 2 == 1;
                    var cardIndex = (index + 1).ToString("00");
                    var delay = 120 + (index * 90);
                    var mediaOrderClass = isReversed ? "lg:order-2" : string.Empty;
                    var contentOrderClass = isReversed ? "lg:order-1" : string.Empty;
                    var imageCountLabel = group.PageImageCount > 0
                        ? $"{group.PageImageCount} ảnh menu"
                        : "Chưa có ảnh menu";

                    <article class="menu-hub-card grid overflow-hidden lg:grid-cols-[0.48fr_0.52fr]" data-uw-reveal="fade-up" data-uw-delay="@delay">
                        <a href="@group.Url"
                           class="menu-hub-card__media @mediaOrderClass"
                           data-menu-hub-media
                           aria-label="Xem thực đơn @group.Name">
                            <div class="menu-hub-card__fallback">
                                <span class="text-xs font-bold uppercase tracking-[0.24em] text-red-300">Truyền Thuyết Champong</span>
                                <strong class="max-w-sm text-3xl font-black leading-none text-white">@group.Name</strong>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(group.CoverImageUrl))
                            {
                                <img src="@group.CoverImageUrl"
                                     alt="@group.Name"
                                     class="menu-hub-card__image"
                                     loading="@(index == 0 ? "eager" : "lazy")"
                                     fetchpriority="@(index == 0 ? "high" : "auto")"
                                     onerror="this.closest('[data-menu-hub-media]')?.classList.add('is-image-missing'); this.remove();" />
                            }
                        </a>

                        <div class="flex flex-col justify-center p-6 sm:p-8 lg:p-10 xl:p-12 @contentOrderClass">
                            <div class="flex flex-wrap items-center gap-3">
                                <span class="inline-flex rounded-full border border-brand-red/30 bg-brand-red/15 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-red-300">
                                    @cardIndex
                                </span>
                                <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-semibold text-white/60">
                                    @imageCountLabel
                                </span>
                            </div>

                            <h2 class="public-card-title-lg mt-6 text-white">
                                @group.Name
                            </h2>
                            <p class="mt-5 max-w-2xl text-base leading-8 text-white/70 sm:text-lg">
                                @group.ShortDescription
                            </p>

                            @if (!string.IsNullOrWhiteSpace(group.Description))
                            {
                                <p class="mt-4 max-w-2xl text-sm leading-7 text-white/50">
                                    @group.Description
                                </p>
                            }

                            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
                                <a href="@group.Url"
                                   class="inline-flex w-full items-center justify-center rounded-full bg-brand-red px-6 py-3 text-sm font-bold uppercase tracking-[0.16em] text-white shadow-[0_18px_44px_rgba(229,9,20,0.24)] transition duration-300 hover:bg-brand-redDark sm:w-auto">
                                    Xem thực đơn
                                </a>
                                <span class="text-sm font-medium text-white/45">
                                    Cập nhật bởi nhà hàng
                                </span>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="mx-auto mt-14 max-w-3xl rounded-[2rem] border border-white/10 bg-white/[0.045] p-8 text-center shadow-[0_28px_80px_rgba(0,0,0,0.32)] backdrop-blur" data-uw-reveal="fade-up" data-uw-delay="120">
                <span class="inline-flex rounded-full border border-brand-red/30 bg-brand-red/10 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.24em] text-red-300">
                    Đang cập nhật
                </span>
                <h2 class="mt-5 text-2xl font-black text-white sm:text-3xl">
                    Chưa có nhóm thực đơn nào được hiển thị.
                </h2>
                <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-white/65 sm:text-base">
                    Các nhóm thực đơn sẽ xuất hiện tại đây sau khi được quản trị viên bật hiển thị.
                </p>
                <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:justify-center">
                    <a href="/" class="inline-flex items-center justify-center rounded-full bg-brand-red px-6 py-3 text-sm font-bold uppercase tracking-[0.16em] text-white transition duration-300 hover:bg-brand-redDark">
                        Quay lại trang chủ
                    </a>
                    <a href="/lien-he" class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/[0.04] px-6 py-3 text-sm font-bold uppercase tracking-[0.16em] text-white/75 transition duration-300 hover:border-brand-red/50 hover:text-white">
                        Liên hệ
                    </a>
                </div>
            </div>
        }
    </div>
</section>
