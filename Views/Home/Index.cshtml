@model HomeIndexViewModel

@{
    ViewData["Title"] = "Truyền Thuyết Champong - Trải nghiệm ẩm thực Hàn Quốc đậm vị và hiện đại";
    ViewData["MetaDescription"] = "Khám phá câu chuyện thương hiệu, tinh hoa ẩm thực và những điểm nhấn tạo nên trải nghiệm dùng bữa đậm vị, sum vầy và hiện đại tại Champong.";

    var menuBrandCards = new[]
    {
        (
            Title: "Truyền Thuyết Champong",
            Description: "Mì hải sản cay nồng, nước dùng đậm vị Hàn Quốc và tinh thần signature của hệ thống.",
            Href: "/thuc-don/nhom/truyen-thuyet-champong",
            ImageUrl: "/images/home/images/truyen-thuyet-champong.webp",
            Alt: "Món Truyền Thuyết Champong",
            Delay: 0
        ),
        (
            Title: "Gogimaru",
            Description: "Thịt nướng chuẩn vị, nổi bật với tinh thần dry-aged và trải nghiệm BBQ cao cấp.",
            Href: "/thuc-don/nhom/gogimaru",
            ImageUrl: "/images/home/images/gogimaru-img.webp",
            Alt: "Bàn tiệc Gogimaru",
            Delay: 120
        ),
        (
            Title: "KBB Cook",
            Description: "Bàn nướng hiện đại, món ăn chia sẻ và không khí tụ họp trẻ trung.",
            Href: "/thuc-don/nhom/kbb-cook",
            ImageUrl: "/images/home/images/kbb-cook-img.png",
            Alt: "Không gian và món nướng KBB Cook",
            Delay: 240
        )
    };
    var homeNewsPosts = Model.LatestPosts.Take(3).ToList();
}

<section class="champong-hero relative overflow-hidden bg-brand-black" data-home-section="hero">
    <div data-champong-hero-slider class="champong-hero__slider relative overflow-hidden" aria-roledescription="carousel" aria-label="Champong hero slider">
        <article data-champong-hero-slide class="champong-hero__slide champong-hero__slide--one is-active absolute inset-0 z-20 opacity-100" aria-hidden="false">
            <div class="champong-hero__media" aria-hidden="true"></div>
            <div class="champong-hero__overlay" aria-hidden="true"></div>

            <div class="container-page champong-hero__inner">
                <div class="champong-hero__content champong-hero__content--left">
                    <span data-champong-hero-reveal class="champong-hero__eyebrow champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="0">
                        PREMIUM KOREAN DINING EXPERIENCE
                    </span>
                    <h1 data-champong-hero-reveal class="champong-hero__title champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="140">
                        Champong cho những bữa ăn có gu.
                    </h1>
                    <p data-champong-hero-reveal class="champong-hero__description champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="280">
                        Không gian hiện đại, nhịp phục vụ chỉn chu và thực đơn đậm vị tạo nên một điểm hẹn dễ nhớ cho khách ghé thăm.
                    </p>

                    <div data-champong-hero-reveal class="champong-hero__actions champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="420">
                        <a href="/dat-ban" class="champong-hero__btn champong-hero__btn--primary">
                            Đặt bàn ngay
                        </a>
                        <a href="/thuc-don" data-uw-reveal="fade-up" class="champong-hero__btn champong-hero__btn--ghost">
                            Xem thực đơn
                        </a>
                    </div>
                </div>
            </div>
        </article>

        <article data-champong-hero-slide hidden class="champong-hero__slide champong-hero__slide--two absolute inset-0 z-10 opacity-0" aria-hidden="true">
            <div class="champong-hero__media" aria-hidden="true"></div>
            <div class="champong-hero__overlay champong-hero__overlay--right" aria-hidden="true"></div>

            <div class="container-page champong-hero__inner">
                <div class="champong-hero__content champong-hero__content--right">
                    <span data-champong-hero-reveal class="champong-hero__eyebrow champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="0">
                        SIGNATURE CHAMPONG FLAVOURS
                    </span>
                    <h2 data-champong-hero-reveal class="champong-hero__title champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="140">
                        Hương vị đậm đà, nâng nhịp mọi cuộc gặp.
                    </h2>
                    <p data-champong-hero-reveal class="champong-hero__subtitle champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="240">
                        Đậm vị Hàn Quốc trong một không gian hiện đại và gần gũi.
                    </p>
                    <p data-champong-hero-reveal class="champong-hero__description champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="340">
                        Sự cân bằng giữa món ăn, ánh sáng và nhịp phục vụ giúp Champong giữ được cảm giác mới mẻ nhưng vẫn dễ quay lại.
                    </p>

                    <div data-champong-hero-reveal class="champong-hero__actions champong-hero__actions--right champong-hero__layer" data-uw-reveal="fade-up" data-champong-hero-delay="480">
                        <a href="/thuc-don" class="champong-hero__btn champong-hero__btn--primary">
                            Khám phá thực đơn
                        </a>
                        <a href="/chi-nhanh" data-uw-reveal="fade-up" class="champong-hero__btn champong-hero__btn--ghost">
                            Xem chi nhánh
                        </a>
                    </div>
                </div>
            </div>
        </article>

        <button type="button" class="champong-hero__nav champong-hero__nav--prev" aria-label="Previous slide" data-champong-hero-prev>
            <svg viewBox="0 0 24 24" class="size-5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 18l-6-6 6-6"></path>
            </svg>
        </button>
        <button type="button" class="champong-hero__nav champong-hero__nav--next" aria-label="Next slide" data-champong-hero-next>
            <svg viewBox="0 0 24 24" class="size-5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 6l6 6-6 6"></path>
            </svg>
        </button>

        <div class="champong-hero__dots" aria-label="Slide navigation">
            <button type="button" class="champong-hero__dot" aria-label="Go to slide 1" aria-current="true" data-champong-hero-dot="0"></button>
            <button type="button" class="champong-hero__dot" aria-label="Go to slide 2" aria-current="false" data-champong-hero-dot="1"></button>
        </div>
    </div>
</section>

<section class="home-brand-story-dark section-shell relative isolate overflow-hidden" data-home-section="brand-story">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <div class="absolute -left-20 top-8 size-72 rounded-full border border-white/6"></div>
        <div class="absolute right-[8%] top-12 size-[26rem] rounded-full border border-white/8"></div>
        <div class="absolute right-[16%] top-[20%] size-[20rem] rounded-full bg-white/[0.03] blur-3xl"></div>
        <div class="absolute bottom-0 left-1/2 h-px w-[min(72rem,92vw)] -translate-x-1/2 bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
    </div>

    <div class="container-page relative z-10">
        <div class="grid gap-10 lg:grid-cols-[0.43fr_0.57fr] lg:items-center">
            <div class="max-w-xl" data-uw-reveal="fade-up">
                <p class="text-xs font-black uppercase tracking-[0.34em] text-brand-red">CÂU CHUYỆN THƯƠNG HIỆU</p>
                <h2 class="public-section-title mt-4 text-white">
                    Không chỉ là một bữa ăn
                </h2>
                <p class="mt-5 max-w-[42rem] text-base leading-8 text-white sm:text-lg">
                    Truyền Thuyết Champong mang tinh thần ẩm thực Hàn Quốc vào những bữa ăn gần gũi tại Việt Nam. Từ chi nhánh đầu tiên tại Phú Mỹ Hưng, thương hiệu từng bước trở thành điểm hẹn quen thuộc cho những ai yêu thích món Hàn chuẩn vị.
                </p>

                <div class="mt-8 flex flex-wrap gap-3" data-uw-reveal="fade-up" data-uw-delay="120">
                    <a href="/gioi-thieu" class="inline-flex items-center justify-center rounded-full bg-brand-red px-5 py-3 text-sm font-semibold uppercase tracking-[0.14em] text-white shadow-soft transition duration-200 hover:bg-brand-redDark">
                        Khám phá KIG Holding
                    </a>
                    <a href="/chi-nhanh" class="inline-flex items-center justify-center rounded-full border border-white/18 bg-white/[0.04] px-5 py-3 text-sm font-semibold uppercase tracking-[0.14em] text-white transition duration-200 hover:border-white/35 hover:bg-white/[0.08]">
                        Xem chi nhánh
                    </a>
                </div>

                <div class="mt-8 grid gap-4 sm:grid-cols-2" data-uw-reveal="fade-up" data-uw-delay="100">
                    @{
                        var storyItems = new[]
                        {
                            ("~/images/home/icons/icons8-origin-50.png", "Phú Mỹ Hưng", "Chi nhánh đầu tiên"),
                            ("~/images/home/icons/icons8-shop-64.png", "3+ năm", "Hình thành và phát triển"),
                            ("~/images/home/icons/icons8-korea-50.png", "Chuẩn vị Hàn", "Dấu ấn ẩm thực Kim Chi"),
                            ("~/images/home/icons/icons8-restaurant-50.png", "An tâm", "Chọn lọc kỹ, chế biến chỉn chu")
                        };
                    }

                    @for (var i = 0; i < storyItems.Length; i++)
                    {
                        var item = storyItems[i];

                        <article class="flex items-start gap-3 rounded-2xl border border-white/8 bg-white/[0.03] px-4 py-3" data-uw-reveal="fade-up" data-uw-delay="@(160 + (i * 60))">
                            <img src="@item.Item1" asp-append-version="true" alt="@item.Item2" class="mt-0.5 h-11 w-11 shrink-0 object-contain" />
                            <div>
                                <p class="text-sm font-black uppercase tracking-[0.08em] text-brand-red sm:text-base">@item.Item2</p>
                                <p class="mt-1 text-sm leading-7 text-white/70">@item.Item3</p>
                            </div>
                        </article>
                    }
                </div>
            </div>

            <div class="relative mx-auto w-full max-w-3xl" data-uw-reveal="fade-up" data-uw-delay="160">
                <div class="absolute left-1/2 top-1/2 h-[26rem] w-[26rem] -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/10" aria-hidden="true"></div>
                <div class="absolute left-1/2 top-1/2 h-[20rem] w-[20rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/[0.04] blur-3xl" aria-hidden="true"></div>
                <div class="absolute left-[10%] top-[12%] size-20 rounded-full border border-brand-red/12 bg-brand-red/6" aria-hidden="true"></div>
                <div class="absolute bottom-[12%] right-[10%] size-24 rounded-full border border-brand-goldSoft/12 bg-brand-goldSoft/10" aria-hidden="true"></div>

                <div class="relative mx-auto w-full max-w-[38rem]">
                    <img src="~/images/home/images/korean-food-no-bg.png" asp-append-version="true" alt="Món ăn Hàn Quốc đặc trưng của Truyền Thuyết Champong" class="relative z-10 w-full object-contain drop-shadow-[0_28px_60px_rgba(0,0,0,0.45)]" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-culinary-essence section-shell relative isolate overflow-hidden" data-home-section="culinary-essence">
    <div class="home-culinary-essence__pattern" aria-hidden="true"></div>
    <div class="container-page relative z-10">
        <div class="relative mx-auto max-w-5xl text-center">
            <img src="~/images/home/images/soyu-bottle-img.png" asp-append-version="true" alt="" aria-hidden="true" class="home-culinary-essence__float home-culinary-essence__float--soyu hidden w-20 sm:block lg:w-28" />
            <img src="~/images/home/images/kimchi-img.png" asp-append-version="true" alt="" aria-hidden="true" class="home-culinary-essence__float home-culinary-essence__float--kimchi hidden w-24 sm:block lg:w-32" />
            <img src="~/images/home/images/spicy-noodle-img.png" asp-append-version="true" alt="" aria-hidden="true" class="home-culinary-essence__float home-culinary-essence__float--noodle hidden w-28 sm:block lg:w-40z" />
            <img src="~/images/home/images/chilli-img.png" asp-append-version="true" alt="" aria-hidden="true" class="home-culinary-essence__float home-culinary-essence__float--chilli hidden w-16 sm:block lg:w-24" />

            <div class="mx-auto max-w-[46rem]" data-uw-reveal="fade-up">
                <p class="text-xs font-black uppercase tracking-[0.34em] text-white/60">Korean dining spirit</p>
                <h2 class="home-culinary-essence__title mt-4 font-black uppercase tracking-[-0.045em] text-brand-red">
                    TINH HOA ẨM THỰC<br />
                    <span class="text-white">GỬI TRỌN ĐAM MÊ</span>
                </h2>
                <p class="mx-auto mt-5 max-w-2xl text-sm leading-7 text-white/80 sm:text-base">
                    "Ăn là sẽ nhớ - nhớ rồi sẽ tới ăn"
                </p>
                <p class="mx-auto mt-5 max-w-2xl text-sm leading-7 text-white/80 sm:text-base">
                    - KIG HOLDING -
                </p>
            </div>
        </div>

        <div class="mt-14 space-y-14 lg:mt-20 lg:space-y-20">
            <article class="home-culinary-essence__block grid gap-8 lg:grid-cols-[0.96fr_1.04fr] lg:items-center lg:gap-14">
                <div class="home-culinary-essence__image" data-uw-reveal="fade-up" data-uw-delay="100">
                    <img src="~/images/home/images/truyen-thuyet-champong.webp" asp-append-version="true" alt="Món Truyền Thuyết Champong" class="h-full w-full object-cover" />
                </div>

                <div>
                    <div data-uw-reveal="fade-up" data-uw-delay="180">
                        <p class="text-xs font-black uppercase tracking-[0.28em] text-brand-red">Signature spicy noodle</p>
                        <h3 class="public-card-title-lg mt-3 uppercase text-brand-red">
                            Truyền Thuyết ChamPong- 전설의 짬뽕
                        </h3>
                        
                    </div>

                    <div class="mt-8 grid gap-5 sm:grid-cols-2">
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="260">
                            <img src="~/images/home/icons/team-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Phù hợp đi theo nhóm</h4>
                            <p>Với mỗi phần ăn có thể phục vụ cho 2-3 người, Truyền thuyết Champong là nơi lý tưởng để họp mặt gia đình , bạn bè, đồng nghiệp.</p>
                        </div>
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="340">
                            <img src="~/images/home/icons/vegetable-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Nguyên liệu đa dạng</h4>
                            <p>Nguồn nguyên liệu tươi mới mỗi ngày và đa dạng : bò, heo, mực, ghẹ biển, bạch tuộc, ốc móng tay, vẹm...</p>
                        </div>
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="420">
                            <img src="~/images/home/icons/noodle-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Sợi mì tươi tự làm</h4>
                            <p>Mì tươi do chính đầu bếp người hàn thực hiện từ những khâu nhỏ nhất, đảm bảo không chất bảo quản.</p>
                        </div>
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="500">
                            <img src="~/images/home/icons/korea-icon-symbol.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Hương vị chuẩn Hàn</h4>
                            <p>Với các gia vị hầu hết nhập khẩu chính gốc từ Hàn, đem đến hương vị chuẩn chỉnh đúng nguyên bản, khó tìm được hương vị này ở nơi khác.</p>
                        </div>
                    </div>
                </div>
            </article>

            <article class="home-culinary-essence__block grid gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:items-center lg:gap-14">
                <div class="lg:order-1">
                    <div data-uw-reveal="fade-up" data-uw-delay="100">
                        <p class="text-xs font-black uppercase tracking-[0.28em] text-brand-red">Korean BBQ table</p>
                        <h3 class="public-card-title-lg mt-3 uppercase text-brand-red">
                            GOGIMARU - 고기마루 고기 숙성 전문
                        </h3>
                    
                    </div>

                    <div class="mt-8 grid gap-5 sm:grid-cols-3 lg:grid-cols-3">
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="180">
                            <img src="~/images/home/icons/korea-icon-symbol.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Đúng chuẩn Hàn Quốc</h4>
                                <p>Thưởng thức bữa thịt nướng trọn vẹn, đúng chuẩn bản xứ khi ăn cùng với nhiều loại panchan và các món như trứng hấp, mì lạnh,...</p>
                        </div>
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="260">
                            <img src="~/images/home/icons/meat-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Thịt nướng chọn lọc</h4>
                                <p>Thịt tươi không tẩm ướp gia vị sẽ được các đầu bếp ủ lên men theo công thức đặc biệt trong 15 ngày trước khi phục vụ thực khách</p>
                        </div>
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="340">
                            <img src="~/images/home/icons/space-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Không gian cực chill</h4>
                            <p>Nhà hàng sân thượng cực chill để bạn thưởng thức đặc biệt nướng ngoài trời lý tưởng, tạo nên bữa tối hoàn hảo.</p>
                        </div>
                    </div>
                </div>

                <div class="home-culinary-essence__image lg:order-2" data-uw-reveal="fade-up" data-uw-delay="420">
                    <img src="~/images/home/images/gogimaru-img.webp" asp-append-version="true" alt="Bàn tiệc Gogimaru" class="h-full w-full object-cover" />
                </div>
            </article>

            <article class="home-culinary-essence__block grid gap-8 lg:grid-cols-[0.96fr_1.04fr] lg:items-center lg:gap-14" data-uw-reveal="fade-up">
                <div class="home-culinary-essence__image" data-uw-reveal="fade-up" data-uw-delay="0">
                    <img src="~/images/home/images/kbb-cook-img.png" asp-append-version="true" alt="Không gian và món nướng KBB Cook" class="h-full w-full object-cover" />
                </div>

                <div>
                    <div data-uw-reveal="fade-up" data-uw-delay="80">
                        <p class="text-xs font-black uppercase tracking-[0.28em] text-brand-red">KOREAN BBQ TABLE</p>
                        <h3 class="public-card-title-lg mt-3 uppercase text-brand-red">
                            KBB COOK – 프리미엄 BBQ & 런치 전문점
                        </h3>
                    </div>

                    <div class="mt-8 grid gap-5 sm:grid-cols-2">
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="160">
                            <img src="~/images/home/icons/bbq-grill-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Nướng chuẩn vị</h4>
                            <p>Bàn nướng nóng hổi, hương vị đậm đà và cách thưởng thức đúng tinh thần BBQ Hàn Quốc.</p>
                        </div>
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="220">
                            <img src="~/images/home/icons/fresh-ingredients-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Nguyên liệu tươi</h4>
                            <p>Thịt, hải sản và rau ăn kèm được chọn lọc kỹ để giữ trọn độ ngon khi phục vụ.</p>
                        </div>
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="280">
                            <img src="~/images/home/icons/team-table-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Bữa ăn sum vầy</h4>
                            <p>Không gian phù hợp cho nhóm bạn, gia đình và những buổi tụ họp ấm cúng.</p>
                        </div>
                        <div class="home-culinary-essence__feature" data-uw-reveal="fade-up" data-uw-delay="340">
                            <img src="~/images/home/icons/various-side-dish-icon.png" asp-append-version="true" alt="" aria-hidden="true" class="h-11 w-11 object-contain" />
                            <h4>Món ăn kèm đa dạng</h4>
                            <p>Các món phụ kiểu Hàn giúp bữa nướng thêm tròn vị và phong phú hơn.</p>
                        </div>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="home-menu-teaser section-shell" data-home-section="menu">
    <div class="container-page">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-3xl" data-uw-reveal="fade-up" data-uw-once="true">
                <p class="text-xs font-black uppercase tracking-[0.28em] text-brand-red">Thực đơn</p>
                <h2 class="public-section-title mt-4 text-white">
                    Ba trải nghiệm vị giác chủ lực
                </h2>
                <p class="mt-5 max-w-2xl text-base leading-8 text-white/72 sm:text-lg">
                    Khám phá ba concept ẩm thực nổi bật trong hệ thống KIG Holding.
                </p>
            </div>

            <a href="/thuc-don"
               class="inline-flex items-center gap-2 self-start text-sm font-semibold uppercase tracking-[0.16em] text-white/64 transition hover:text-white"
               data-uw-reveal="fade-up"
               data-uw-delay="80"
               data-uw-once="true">
                Xem toàn bộ thực đơn
                <span aria-hidden="true" class="transition duration-300">→</span>
            </a>
        </div>

        <div class="home-menu-teaser__grid mt-12">
            @foreach (var card in menuBrandCards)
            {
                <article class="home-menu-teaser__card"
                         data-uw-reveal="fade-up"
                         data-uw-delay="@card.Delay"
                         data-uw-once="true">
                    <div class="home-menu-teaser__media" data-media-parent>
                        <img src="@card.ImageUrl"
                             alt="@card.Alt"
                             class="home-menu-teaser__image"
                             loading="lazy"
                             onerror="this.closest('[data-media-parent]')?.classList.add('is-image-missing'); this.remove();" />
                        <div class="home-menu-teaser__overlay" aria-hidden="true"></div>
                    </div>

                    <div class="home-menu-teaser__content">
                        <div class="max-w-[18rem]">
                            <h3 class="home-menu-teaser__title">@card.Title</h3>
                            <p class="home-menu-teaser__description">@card.Description</p>
                        </div>

                        <a href="@card.Href"
                           class="home-menu-teaser__cta"
                           aria-label="Xem thực đơn @card.Title">
                            <span aria-hidden="true">→</span>
                        </a>
                    </div>
                </article>
            }
        </div>
    </div>
</section>

<section class="champong-takehome section-shell" data-home-section="take-home">
    <div class="container-page">
        <div class="grid gap-10 lg:grid-cols-[0.52fr_0.48fr] lg:items-center">
            <div data-uw-reveal="fade-up" data-uw-once="true">
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-red">Mang Champong về nhà</p>
                <h2 class="public-section-title--featured mt-4 max-w-xl text-white">
                    Mang <span class="text-brand-red">Champong</span><br />về nhà
                </h2>
                <p class="mt-6 max-w-xl text-base leading-8 text-white">
                    Một khoảng dừng nhẹ, sạch và đủ ấm để gợi mở cảm giác thưởng thức Champong ở nhà, trong những bữa sum vầy nhỏ hoặc các dịp muốn giữ nhịp ăn ngon thật gọn gàng.
                </p>
            </div>

            <div class="champong-takehome__visual mx-auto w-full max-w-[34rem]" data-media-parent data-uw-reveal="fade-up" data-uw-delay="100" data-uw-once="true">
                <img src="/images/home/images/champong-mascot.webp"
                     alt="Linh vật Truyền Thuyết Champong"
                     class="champong-takehome__mascot"
                     loading="lazy"
                     decoding="async"
                     onerror="this.closest('[data-media-parent]')?.classList.add('is-image-missing'); this.remove();" />

                <a href="/thuc-don"
                   class="champong-takehome__button inline-flex items-center justify-center rounded-full bg-brand-red px-6 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-white transition duration-200 hover:bg-brand-redDark"
                   aria-label="Đặt Champong mang về">
                    Đặt ngay
                </a>
            </div>
        </div>
    </div>
</section>

<section class="home-news-section home-news-section--dark section-shell relative isolate overflow-hidden" data-home-section="news">
    <div class="container-page relative z-10">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-[48rem]" data-uw-reveal="fade-up">
                <p class="text-xs font-black uppercase tracking-[0.34em] text-brand-red">TIN TỨC & ƯU ĐÃI</p>
                <h2 class="public-section-title mt-5 text-white">
                    Cập nhật mới từ Truyền Thuyết Champong
                </h2>
                <p class="mt-6 max-w-[44rem] text-sm leading-7 text-white sm:text-[1.04rem] sm:leading-8">
                    Khám phá các chương trình mới, thông tin chi nhánh, sự kiện và những cập nhật mới nhất từ Truyền Thuyết Champong.
                </p>
            </div>

            <div class="flex flex-wrap items-center gap-4" data-uw-reveal="fade-up" data-uw-delay="100">
                @if (homeNewsPosts.Count > 0)
                {
                    <span class="inline-flex items-center rounded-full border border-white/12 bg-white/[0.06] px-4 py-2.5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white shadow-[0_14px_32px_rgba(0,0,0,0.16)] backdrop-blur">
                        @homeNewsPosts.Count bài viết mới
                    </span>
                }

                <a href="/tin-tuc" class="inline-flex items-center justify-center rounded-full bg-brand-red px-6 py-3.5 text-[0.82rem] font-semibold uppercase tracking-[0.16em] text-white shadow-[0_18px_36px_rgba(229,9,20,0.24)] transition duration-300 hover:-translate-y-0.5 hover:bg-brand-redDark">
                    Xem tất cả tin tức
                </a>
            </div>
        </div>

        @if (homeNewsPosts.Count > 0)
        {
            var leadPost = homeNewsPosts[0];
            var supportingPosts = homeNewsPosts.Skip(1).Take(2).ToList();
            var editorialLayoutClass = supportingPosts.Count > 0
                ? "grid gap-6 xl:gap-7 lg:grid-cols-[1.12fr_0.88fr] lg:items-start"
                : "max-w-5xl";

            <div class="mt-12 flex items-center justify-between gap-4" data-uw-reveal="fade-up" data-uw-delay="140">
                <p class="text-xs font-black uppercase tracking-[0.28em] text-white">Nổi bật trong tuần</p>
                <a href="/tin-tuc" class="hidden text-sm font-semibold text-white transition hover:text-white sm:inline-flex">
                    Xem trang tin tức
                </a>
            </div>

            <div class="mt-7 @editorialLayoutClass">
                <article class="home-news-card home-news-card--lead group" data-uw-reveal="fade-up" data-uw-delay="180">
                    <a href="@leadPost.Url" class="flex h-full flex-col">
                        <div class="home-news-card__media" data-home-news-media>
                            <div class="home-news-card__fallback home-news-card__fallback--lead">
                                <span class="home-news-card__eyebrow">Truyền Thuyết Champong</span>
                                <p class="home-news-card__title">@leadPost.Title</p>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(leadPost.ImageUrl))
                            {
                                <img src="@leadPost.ImageUrl"
                                     alt="@leadPost.Title"
                                     class="home-news-card__image"
                                     loading="lazy"
                                     onerror="this.closest('[data-home-news-media]')?.classList.add('is-image-missing'); this.remove();" />
                            }
                        </div>

                        <div class="flex flex-1 flex-col p-6 sm:p-7 lg:p-6 xl:p-7">
                            <div class="flex flex-wrap items-center gap-3">
                                <span class="inline-flex rounded-full border border-brand-red/25 bg-brand-red/14 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.16em] text-red-300">
                                    @leadPost.Category
                                </span>
                                @if (leadPost.PublishedAt.HasValue)
                                {
                                    <span class="text-xs font-medium uppercase tracking-[0.14em] text-white/60">
                                        @leadPost.PublishedAt.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                            </div>

                            <h3 class="mt-4 text-2xl font-black leading-tight text-white sm:text-[2rem] xl:max-w-[28rem]">
                                @leadPost.Title
                            </h3>

                            @if (!string.IsNullOrWhiteSpace(leadPost.Excerpt))
                            {
                                <p class="mt-4 max-w-2xl text-sm leading-7 text-white sm:text-base sm:leading-8">
                                    @leadPost.Excerpt
                                </p>
                            }

                            <div class="mt-7 flex items-center gap-2 text-sm font-semibold text-brand-red transition group-hover:text-white">
                                <span>Đọc tiếp</span>
                                <span aria-hidden="true" class="transition duration-300 group-hover:translate-x-1">→</span>
                            </div>
                        </div>
                    </a>
                </article>

                @if (supportingPosts.Count > 0)
                {
                    <div class="grid gap-6">
                        @for (var i = 0; i < supportingPosts.Count; i++)
                        {
                            var post = supportingPosts[i];

                            <article class="home-news-card home-news-card--support group h-full" data-uw-reveal="fade-up" data-uw-delay="@(240 + (i * 80))">
                                <a href="@post.Url" class="flex h-full flex-col sm:flex-row lg:flex-col">
                                    <div class="home-news-card__media" data-home-news-media>
                                        <div class="home-news-card__fallback">
                                            <span class="home-news-card__eyebrow">Tin mới</span>
                                            <p class="home-news-card__title text-base sm:text-lg">@post.Title</p>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(post.ImageUrl))
                                        {
                                            <img src="@post.ImageUrl"
                                                 alt="@post.Title"
                                                 class="home-news-card__image"
                                                 loading="lazy"
                                                 onerror="this.closest('[data-home-news-media]')?.classList.add('is-image-missing'); this.remove();" />
                                        }
                                    </div>

                                    <div class="flex flex-1 flex-col p-5 sm:p-6">
                                        <div class="flex flex-wrap items-center gap-3">
                                            <span class="inline-flex rounded-full border border-brand-red/25 bg-brand-red/14 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.16em] text-red-300">
                                                @post.Category
                                            </span>
                                            @if (post.PublishedAt.HasValue)
                                            {
                                                <span class="text-xs font-medium uppercase tracking-[0.14em] text-white/60">
                                                    @post.PublishedAt.Value.ToString("dd/MM/yyyy")
                                                </span>
                                            }
                                        </div>

                                        <h3 class="mt-4 text-xl font-black leading-tight text-white">
                                            @post.Title
                                        </h3>

                                        @if (!string.IsNullOrWhiteSpace(post.Excerpt))
                                        {
                                            <p class="mt-3 text-sm leading-7 text-white">
                                                @post.Excerpt
                                            </p>
                                        }

                                        <div class="mt-5 flex items-center gap-2 text-sm font-semibold text-brand-red transition group-hover:text-white">
                                            <span>Đọc tiếp</span>
                                            <span aria-hidden="true" class="transition duration-300 group-hover:translate-x-1">→</span>
                                        </div>
                                    </div>
                                </a>
                            </article>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="mt-10 rounded-[1.6rem] border border-white/10 bg-white/[0.045] p-7 shadow-[0_24px_70px_rgba(0,0,0,0.24)] backdrop-blur" data-uw-reveal="fade-up" data-uw-delay="160">
                <p class="text-lg font-black text-white">Chưa có bài viết mới.</p>
                <p class="mt-3 max-w-2xl text-sm leading-7 text-white/70 sm:text-base">
                    Các cập nhật mới từ Truyền Thuyết Champong sẽ sớm được đăng tải.
                </p>
                <a href="/tin-tuc" class="mt-6 inline-flex items-center justify-center rounded-full bg-brand-red px-5 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-white shadow-soft transition duration-300 hover:-translate-y-0.5 hover:bg-brand-redDark">
                    Xem trang tin tức
                </a>
            </div>
        }
    </div>
</section>

<section data-home-section="booking"
         class="home-booking-cta"
         data-uw-reveal="fade-up"
         data-uw-once="true">
    <div class="home-booking-cta__overlay"></div>

    <div class="section-shell home-booking-cta__inner">
        <div class="container-page">
            <div class="home-booking-cta__content"
                 data-uw-reveal="fade-up"
                 data-uw-delay="80"
                 data-uw-once="true">
                <p class="home-booking-cta__eyebrow">Reservation</p>

                <h2 class="home-booking-cta__title">
                    Đặt bàn trước cho trải nghiệm trọn vẹn
                </h2>

                <p class="home-booking-cta__description">
                    Giữ chỗ trước để đội ngũ Truyền Thuyết Champong chuẩn bị không gian
                    và trải nghiệm dùng bữa chỉn chu dành cho bạn.
                </p>

                <a href="/dat-ban"
                   class="btn-primary home-booking-cta__button"
                   aria-label="Đi tới trang đặt bàn">
                    Đặt bàn ngay
                </a>
            </div>
        </div>
    </div>
</section>
@section Scripts {
    <script src="~/js/home-hero-slider.js" asp-append-version="true"></script>
}
