@model KIGHolding.ViewModels.Shared.HeaderViewModel

<header data-site-header class="site-header">
    <nav class="container-page flex h-20 items-center gap-6 xl:gap-10 lg:h-[5.5rem]">
        <a href="/" class="group flex shrink-0 items-center gap-3" aria-label="@Model.BrandName">
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <img src="@Model.LogoUrl" alt="@Model.BrandName" class="h-20 w-20 rounded-full object-contain lg:h-20 lg:w-20" />
            }
            else
            {
                <span class="brand-mark">TT</span>
            }
        </a>
        <div class="hidden flex-1 lg:block">
            <div class="mx-auto flex w-fit items-center gap-8 xl:gap-10">
                @foreach (var item in Model.NavItems)
                {
                    var isReservationItem =
                        string.Equals(item.Url, Model.ReservationUrl, StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(item.Label?.Trim(), "Đặt bàn", StringComparison.OrdinalIgnoreCase);
                    if (!isReservationItem)
                    {
                        if (item.HasChildren)
                        {
                            <div class="group relative">
                                <button type="button"
                                        class="nav-link inline-flex items-center gap-1 @(item.IsActive ? "is-active" : string.Empty) focus-visible:outline-none"
                                        aria-haspopup="true">
                                    <span>@item.Label</span>
                                    <svg class="size-3.5 text-current transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
                                         viewBox="0 0 12 12"
                                         fill="none"
                                         aria-hidden="true">
                                        <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </button>

                                <div class="pointer-events-none absolute right-0 top-full z-50 mt-3 w-64 translate-y-2 rounded-2xl border border-white/10 bg-brand-black/95 p-2 opacity-0 shadow-[0_20px_50px_rgba(0,0,0,0.28)] transition duration-200 ease-out group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100">
                                    <div class="space-y-1">
                                        @foreach (var child in item.Children)
                                        {
                                            <a href="@child.Url"
                                               class="flex items-center justify-between rounded-xl px-4 py-3 text-[13px] font-semibold uppercase tracking-[0.08em] text-white transition-colors hover:bg-white/10 hover:text-white @(child.IsActive ? "bg-brand-red/12 text-brand-red" : string.Empty)">
                                                <span>@child.Label</span>
                                                @if (child.IsActive)
                                                {
                                                    <span class="h-1.5 w-1.5 rounded-full bg-brand-red"></span>
                                                }
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <a href="@item.Url" class="nav-link @(item.IsActive ? "is-active" : string.Empty)">
                                @item.Label
                            </a>
                        }
                    }
                }
            </div>
        </div>

        <div class="hidden shrink-0 items-center lg:flex">
            <a href="@Model.ReservationUrl"
               class="inline-flex items-center rounded-button border border-brand-red/30 bg-brand-red px-5 py-2.5 text-[12px] font-bold uppercase tracking-[0.16em] text-white transition-colors hover:bg-brand-redDark">
                Đặt bàn
            </a>
        </div>

        <button type="button"
                class="ml-auto inline-flex size-11 items-center justify-center rounded-md border border-white/20 bg-white/5 text-white transition hover:border-brand-red hover:text-brand-red lg:hidden"
                aria-label="Mở menu"
                aria-expanded="false"
                data-mobile-menu-open>
            <span class="sr-only">Mở menu</span>
            <span class="flex w-5 flex-col gap-1.5">
                <span class="h-0.5 rounded-full bg-white"></span>
                <span class="h-0.5 rounded-full bg-white"></span>
                <span class="h-0.5 rounded-full bg-white"></span>
            </span>
        </button>
    </nav>

    @await Html.PartialAsync("~/Views/Shared/Partials/_MobileMenu.cshtml", Model)
</header>
