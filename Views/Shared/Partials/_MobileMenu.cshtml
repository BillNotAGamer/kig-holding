@model KIGHolding.ViewModels.Shared.HeaderViewModel

<div class="mobile-drawer-overlay lg:hidden" data-mobile-menu-overlay></div>

<aside class="mobile-drawer lg:hidden"
       id="mobile-menu"
       aria-hidden="true"
       data-mobile-menu>
    <div class="flex h-full flex-col">
        <div class="flex h-20 items-center justify-between border-b border-white/10 px-5">
            <a href="/" class="flex min-w-0 items-center gap-3" aria-label="@Model.BrandName">
                <img src="@Model.LogoUrl" alt="@Model.BrandName" class="h-16 w-16 rounded-full object-contain lg:h-16 lg:w-16" />                
            </a>
            <button type="button"
                    class="grid size-10 place-items-center rounded-md border border-white/20 bg-white/5 text-white transition hover:border-brand-red hover:text-brand-red"
                    aria-label="Đóng menu"
                    data-mobile-menu-close>
                <span class="text-2xl leading-none">&times;</span>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto px-5 py-6">
            <nav class="flex flex-col gap-1">
                @foreach (var item in Model.NavItems)
                {
                    var isReservationItem =
                        string.Equals(item.Url, Model.ReservationUrl, StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(item.Label?.Trim(), "Đặt bàn", StringComparison.OrdinalIgnoreCase);
                    if (!isReservationItem)
                    {
                        if (item.HasChildren)
                        {
                            <details class="group rounded-md border border-white/10 bg-white/[0.04]" @(item.IsActive ? "open" : string.Empty)>
                                <summary class="flex cursor-pointer list-none items-center justify-between gap-3 rounded-md px-3 py-3 text-sm font-semibold uppercase tracking-[0.1em] text-white/80 transition hover:bg-white/10 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-red/70 [&::-webkit-details-marker]:hidden">
                                    <span>@item.Label</span>
                                    <svg class="size-4 shrink-0 text-white/60 transition-transform duration-200 group-open:rotate-180"
                                         viewBox="0 0 12 12"
                                         fill="none"
                                         aria-hidden="true">
                                        <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </summary>
                                <div class="space-y-1 border-t border-white/10 px-3 py-2">
                                    @foreach (var child in item.Children)
                                    {
                                        <a href="@child.Url"
                                           class="block rounded-md px-3 py-2 text-[13px] font-semibold uppercase tracking-[0.08em] transition @(child.IsActive ? "bg-brand-red text-white" : "text-white/70 hover:bg-white/10 hover:text-white")"
                                           data-mobile-menu-link>
                                            @child.Label
                                        </a>
                                    }
                                </div>
                            </details>
                        }
                        else
                        {
                            <a href="@item.Url"
                               class="rounded-md px-3 py-3 text-sm font-semibold uppercase tracking-[0.1em] transition @(item.IsActive ? "bg-brand-red text-white" : "text-white/80 hover:bg-white/10 hover:text-white")"
                               data-mobile-menu-link>
                                @item.Label
                            </a>
                        }
                    }
                }
            </nav>

            <div class="mt-8 rounded-md border border-brand-red/20 bg-white/5 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-red">Hotline</p>
                <a href="tel:@Model.Hotline.Replace(" ", string.Empty)" class="mt-2 block text-2xl font-black text-white transition-colors hover:text-brand-red">
                    @Model.Hotline
                </a>
            </div>
        </div>

        <div class="space-y-3 border-t border-white/10 p-5">
            <a href="@Model.ReservationUrl" class="block w-full rounded-button bg-brand-red px-6 py-3 text-center text-sm font-bold uppercase tracking-[0.16em] text-white transition-colors hover:bg-brand-redDark">Đặt bàn</a>
            <p class="text-center text-[11px] uppercase tracking-[0.18em] text-white/45">
                Hospitality booking support
            </p>
        </div>
    </div>
</aside>
