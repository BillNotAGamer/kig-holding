@model KIGHolding.ViewModels.Shared.HeaderViewModel

<div class="mobile-drawer-overlay lg:hidden" data-mobile-menu-overlay></div>

<aside class="mobile-drawer lg:hidden"
       id="mobile-menu"
       aria-hidden="true"
       data-mobile-menu>
    <div class="flex h-full flex-col">
        <div class="flex h-20 items-center justify-between border-b border-white/10 px-5">
            <a href="/" class="flex min-w-0 items-center gap-3" aria-label="@Model.BrandName">
                <span class="brand-mark">TT</span>
                <span class="truncate text-sm font-bold uppercase tracking-[0.16em] text-white">@Model.BrandName</span>
            </a>
            <button type="button"
                    class="grid size-10 place-items-center rounded-md border border-white/20 bg-white/5 text-white transition hover:border-brand-gold hover:text-brand-goldSoft"
                    aria-label="Đóng menu"
                    data-mobile-menu-close>
                <span class="text-2xl leading-none">&times;</span>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto px-5 py-6">
            <nav class="flex flex-col gap-1">
                @foreach (var item in Model.NavItems)
                {
                    var isReservationItem =
                        string.Equals(item.Url, Model.ReservationUrl, StringComparison.OrdinalIgnoreCase) ||
                        string.Equals(item.Label?.Trim(), "Đặt bàn", StringComparison.OrdinalIgnoreCase);
                    if (!isReservationItem)
                    {
                        <a href="@item.Url"
                           class="rounded-md px-3 py-3 text-sm font-semibold uppercase tracking-[0.1em] transition @(item.IsActive ? "bg-brand-gold text-brand-black" : "text-white/80 hover:bg-white/10 hover:text-white")"
                           data-mobile-menu-link>
                            @item.Label
                        </a>
                    }
                }
            </nav>

            <div class="mt-8 rounded-md border border-brand-gold/20 bg-white/5 p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand-goldSoft">Hotline</p>
                <a href="tel:@Model.Hotline.Replace(" ", string.Empty)" class="mt-2 block text-2xl font-black text-white transition-colors hover:text-brand-goldSoft">
                    @Model.Hotline
                </a>
            </div>
        </div>

        <div class="space-y-3 border-t border-white/10 p-5">
            <a href="@Model.ReservationUrl" class="block w-full rounded-button bg-brand-gold px-6 py-3 text-center text-sm font-bold uppercase tracking-[0.16em] text-brand-black transition-colors hover:bg-brand-goldSoft">Đặt bàn</a>
            <p class="text-center text-[11px] uppercase tracking-[0.18em] text-white/45">
                Hospitality booking support
            </p>
        </div>
    </div>
</aside>
