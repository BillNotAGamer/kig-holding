@model KIGHolding.ViewModels.Shared.FoodCardViewModel

<article class="overflow-hidden rounded-md border border-brand-border bg-white shadow-soft transition-all hover:-translate-y-1 hover:shadow-panel">
    <a href="@Model.Url" class="group block" aria-label="@Model.Name">
        <div class="food-image-wrap aspect-[4/3]">
            <img src="@Model.ImageUrl"
                 alt="@Model.Name"
                 class="food-image"
                 loading="lazy"
                 onerror="this.remove();" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-black/35 via-transparent to-transparent"></div>
            <div class="absolute left-4 top-4 z-30 flex flex-wrap gap-2">
                @if (Model.SpicyLevel > 0)
                {
                    <span class="rounded-button bg-brand-black px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">Cay</span>
                }
                @if (Model.IsBestSeller)
                {
                    <span class="rounded-button bg-brand-goldSoft px-3 py-1 text-xs font-bold uppercase tracking-wide text-brand-dark">Best seller</span>
                }
                @if (Model.IsNew)
                {
                    <span class="rounded-button bg-brand-gold px-3 py-1 text-xs font-bold uppercase tracking-wide text-brand-black">Mới</span>
                }
                @if (Model.IsCombo)
                {
                    <span class="rounded-button border border-brand-border bg-white/90 px-3 py-1 text-xs font-bold uppercase tracking-wide text-brand-dark">Combo</span>
                }
                @if (Model.IsSignature)
                {
                    <span class="rounded-button border border-brand-gold/30 bg-brand-goldSoft/55 px-3 py-1 text-xs font-bold uppercase tracking-wide text-brand-goldDeep">Signature</span>
                }
            </div>
        </div>

        <div class="p-5">
            <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                    @if (!string.IsNullOrWhiteSpace(Model.CategoryName))
                    {
                        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">@Model.CategoryName</p>
                    }
                    <h3 class="mt-2 text-xl font-black text-brand-dark transition group-hover:text-brand-goldDeep">@Model.Name</h3>
                    @if (!string.IsNullOrWhiteSpace(Model.KoreanName))
                    {
                        <p class="mt-1 text-sm text-brand-gray">@Model.KoreanName</p>
                    }
                </div>
                <div class="shrink-0 text-right">
                    <p class="text-lg font-black text-brand-goldDeep">@Model.Price.ToString("N0")đ</p>
                    @if (Model.OriginalPrice.HasValue)
                    {
                        <p class="text-xs text-brand-gray line-through">@Model.OriginalPrice.Value.ToString("N0")đ</p>
                    }
                </div>
            </div>

            <p class="mt-3 line-clamp-2 text-sm leading-6 text-brand-gray">@Model.ShortDescription</p>

            <div class="mt-5 flex items-center justify-between gap-4">
                <div class="flex items-center gap-1" aria-label="Mức cay @Model.SpicyLevel trên 5">
                    @for (var i = 1; i <= 5; i++)
                    {
                        <span class="size-2 rounded-full @(i <= Model.SpicyLevel ? "bg-brand-goldDeep" : "bg-brand-border")"></span>
                    }
                </div>
                <span class="text-sm font-semibold text-brand-dark">Xem món</span>
            </div>
        </div>
    </a>
</article>
