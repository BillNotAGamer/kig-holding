@model KIGHolding.ViewModels.Shared.PostCardViewModel

<article class="overflow-hidden rounded-md border border-brand-border bg-white shadow-soft transition-all hover:-translate-y-1 hover:shadow-panel">
    <a href="@Model.Url" class="group block" aria-label="@Model.Title">
        <div class="food-image-wrap aspect-[16/9]">
            <img src="@Model.ImageUrl"
                 alt="@Model.Title"
                 class="food-image"
                 loading="lazy"
                 onerror="this.remove();" />
            <div class="absolute left-4 top-4 z-30 rounded-button bg-brand-white/92 px-3 py-1 text-xs font-bold uppercase tracking-wide text-brand-goldDeep">
                @Model.Category
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-brand-black/35 via-transparent to-transparent"></div>
        </div>

        <div class="p-5">
            @if (Model.PublishedAt.HasValue)
            {
                <time datetime="@Model.PublishedAt.Value.ToString("yyyy-MM-dd")" class="text-xs uppercase tracking-[0.16em] text-brand-gray">
                    @Model.PublishedAt.Value.ToString("dd/MM/yyyy")
                </time>
            }
            <h3 class="mt-3 text-xl font-black text-brand-dark transition group-hover:text-brand-goldDeep">@Model.Title</h3>
            <p class="mt-3 line-clamp-3 text-sm leading-6 text-brand-gray">@Model.Excerpt</p>
            <span class="mt-5 inline-block text-sm font-semibold text-brand-dark">Đọc thêm</span>
        </div>
    </a>
</article>
