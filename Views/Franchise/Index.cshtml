@{
    ViewData["Title"] = "Liên hệ nhượng quyền";
    ViewData["MetaDescription"] = "Trang liên hệ nhượng quyền KIG Holding đang được hoàn thiện để tiếp nhận trao đổi hợp tác và cơ hội phát triển thương hiệu.";
}

<section class="hero-frame">
    <div class="container-page section-shell">
        <div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
            <div class="hero-card" data-uw-reveal="fade-up">
                <span class="inline-flex rounded-button border border-brand-gold/25 bg-brand-goldSoft/45 px-4 py-2 text-kicker font-black uppercase text-brand-goldDeep">
                    KIG Holding
                </span>
                <h1 class="public-page-title mt-5 text-brand-dark">Liên hệ nhượng quyền</h1>
                <p class="mt-5 text-lead text-brand-gray">
                    Đây là trang giới thiệu sơ bộ dành cho những đối tác quan tâm đến cơ hội hợp tác phát triển thương hiệu cùng KIG Holding.
                </p>

                <div class="mt-7 flex flex-col gap-3 sm:flex-row">
                    <a href="/lien-he" class="btn-primary">Gửi thông tin liên hệ</a>
                    <a href="/chi-nhanh" class="btn-secondary">Tìm chi nhánh gần bạn</a>
                </div>
            </div>

            <div class="surface-panel p-6 sm:p-7" data-uw-reveal="fade-up">
                <p class="text-kicker font-black uppercase text-brand-goldDeep">Đang hoàn thiện</p>
                <h2 class="mt-3 text-3xl font-black text-brand-dark">Một điểm chạm rõ ràng cho trao đổi hợp tác và phát triển khu vực.</h2>
                <p class="mt-4 text-sm leading-7 text-brand-gray">
                    Trang này hiện chỉ đóng vai trò định hướng. Thông tin chính thức về hợp tác, quy trình và điều kiện sẽ được cập nhật khi nội dung được phê duyệt.
                </p>

                <div class="mt-6 grid gap-3 sm:grid-cols-2">
                    <article class="surface-muted p-4">
                        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Phát triển thương hiệu</p>
                        <p class="mt-2 text-sm leading-6 text-brand-gray">Không gian dành cho các trao đổi về định hướng mở rộng trong tương lai.</p>
                    </article>
                    <article class="surface-muted p-4">
                        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Mô hình vận hành</p>
                        <p class="mt-2 text-sm leading-6 text-brand-gray">Tổng quan chung về vận hành sẽ được cập nhật khi có nội dung chính thức.</p>
                    </article>
                    <article class="surface-muted p-4">
                        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Mặt bằng &amp; khu vực</p>
                        <p class="mt-2 text-sm leading-6 text-brand-gray">Các vị trí tiềm năng có thể được trao đổi trực tiếp với đội ngũ phụ trách.</p>
                    </article>
                    <article class="surface-muted p-4">
                        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Kết nối đội ngũ</p>
                        <p class="mt-2 text-sm leading-6 text-brand-gray">KIG Holding sẽ tiếp nhận trao đổi để hỗ trợ bước đầu một cách phù hợp.</p>
                    </article>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-band section-shell">
    <div class="container-page">
        <div class="grid gap-8 lg:grid-cols-[0.45fr_0.55fr] lg:items-start">
            <div data-uw-reveal="fade-up">
                @await Component.InvokeAsync("SectionHeading", new
                {
                    model = new SectionHeadingViewModel
                    {
                        Eyebrow = "Hợp tác",
                        Title = "Khung thông tin ban đầu cho các trao đổi về nhượng quyền.",
                        Description = "Nội dung thực tế sẽ được bổ sung sau khi định hướng hợp tác được chốt và đảm bảo tính nhất quán với toàn bộ hệ thống."
                    }
                })
            </div>

            <div class="grid gap-4 sm:grid-cols-2" data-uw-reveal="fade-up">
                <article class="surface-panel p-5">
                    <p class="text-kicker font-black uppercase text-brand-goldDeep">Trao đổi mô hình</p>
                    <p class="mt-3 text-sm leading-7 text-brand-gray">Gợi ý ban đầu cho các cuộc trao đổi về cách thức phát triển thương hiệu.</p>
                </article>
                <article class="surface-panel p-5">
                    <p class="text-kicker font-black uppercase text-brand-goldDeep">Vị trí tiềm năng</p>
                    <p class="mt-3 text-sm leading-7 text-brand-gray">Có thể dùng trang chi nhánh để tìm khu vực phù hợp trước khi liên hệ.</p>
                </article>
                <article class="surface-panel p-5">
                    <p class="text-kicker font-black uppercase text-brand-goldDeep">Đội ngũ hỗ trợ</p>
                    <p class="mt-3 text-sm leading-7 text-brand-gray">Đầu mối liên hệ sẽ được bổ sung sau khi hoàn thiện chính sách hợp tác.</p>
                </article>
                <article class="surface-panel p-5">
                    <p class="text-kicker font-black uppercase text-brand-goldDeep">Nội dung chính thức</p>
                    <p class="mt-3 text-sm leading-7 text-brand-gray">Các điều kiện cụ thể chưa được công bố tại giai đoạn placeholder này.</p>
                </article>
            </div>
        </div>
    </div>
</section>

<section class="section-shell pt-0 lg:pt-0">
    <div class="container-page">
        <div class="surface-panel p-6 sm:p-8 lg:p-10" data-uw-reveal="fade-up">
            <div class="max-w-3xl">
                <p class="text-kicker font-black uppercase text-brand-goldDeep">Bước tiếp theo</p>
                <h2 class="mt-3 text-3xl font-black text-brand-dark sm:text-4xl">Bắt đầu bằng một cuộc liên hệ hoặc xem chi nhánh hiện có.</h2>
                <p class="mt-4 text-brand-gray">Trang này chưa thu thập dữ liệu nào. Bạn có thể dùng các liên kết dưới đây để đi đến bước tiếp theo phù hợp.</p>
                <div class="mt-7 flex flex-col gap-3 sm:flex-row">
                    <a href="/lien-he" class="btn-primary">Gửi thông tin liên hệ</a>
                    <a href="/chi-nhanh" class="btn-secondary">Tìm chi nhánh gần bạn</a>
                </div>
            </div>
        </div>
    </div>
</section>
