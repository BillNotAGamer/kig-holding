@model ReservationCreateViewModel

@{
    ViewData["Title"] = "Đặt bàn";
    ViewData["MetaDescription"] = "Đặt bàn trước tại Truyền Thuyết Champong. Chọn chi nhánh, thời gian và số khách để giữ bàn nhanh chóng.";
}

<section class="hero-frame" data-reservation-page="index">
    <div class="container-page section-shell">
        <div class="grid gap-8 lg:grid-cols-[1fr_0.45fr] lg:items-end">
            <div class="hero-card max-w-3xl" data-uw-reveal="fade-up">
                <span class="inline-flex rounded-button border border-brand-gold/25 bg-brand-goldSoft/45 px-4 py-2 text-kicker font-black uppercase text-brand-goldDeep">
                    Reservation
                </span>
                <h1 class="mt-5 text-display font-black text-brand-dark sm:text-hero">Đặt bàn trước</h1>
                <p class="mt-5 text-lead text-brand-gray">
                    Luồng booking được chuyển sang giao diện sáng, gọn và dễ đọc hơn để phù hợp một website hospitality cao cấp.
                </p>
            </div>
            <div class="surface-panel p-5" data-uw-reveal="fade-up">
                <p class="text-kicker font-black uppercase text-brand-goldDeep">Cần đặt bàn gấp?</p>
                <a href="tel:@Model.Hotline.Replace(" ", string.Empty)" class="mt-3 block text-3xl font-black text-brand-dark">@Model.Hotline</a>
                <p class="mt-3 text-sm leading-6 text-brand-gray">Gọi hotline để được hỗ trợ nhanh cho khung giờ gần hoặc nhóm đông.</p>
            </div>
        </div>
    </div>
</section>

<section class="section-shell">
    <div class="container-page grid gap-8 lg:grid-cols-[0.68fr_0.32fr]">
        <div class="surface-panel p-5 sm:p-7">
            <div class="mb-7">
                <p class="text-kicker font-black uppercase text-brand-goldDeep">Thông tin giữ bàn</p>
                <h2 class="mt-3 text-3xl font-black text-brand-dark">Hoàn tất đặt bàn</h2>
                <p class="mt-3 text-sm leading-6 text-brand-gray">Thông tin của bạn sẽ được lưu với trạng thái chờ xác nhận. Nhà hàng sẽ liên hệ lại nếu cần làm rõ.</p>
            </div>

            <form asp-action="Index" asp-controller="Reservation" method="post" class="space-y-5" novalidate>
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="ModelOnly" class="rounded-md border border-brand-red/30 bg-brand-red/5 p-4 text-sm text-brand-redDark"></div>
                }

                <div class="grid gap-4 sm:grid-cols-2">
                    <label class="block">
                        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Họ tên</span>
                        <input asp-for="CustomerName" autocomplete="name" class="input-field" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="CustomerName" class="mt-2 block text-sm text-brand-redDark"></span>
                    </label>

                    <label class="block">
                        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Số điện thoại</span>
                        <input asp-for="PhoneNumber" autocomplete="tel" class="input-field" placeholder="0909 888 777" />
                        <span asp-validation-for="PhoneNumber" class="mt-2 block text-sm text-brand-redDark"></span>
                    </label>
                </div>

                <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Email</span>
                    <input asp-for="Email" autocomplete="email" class="input-field" placeholder="email@example.com" />
                    <span asp-validation-for="Email" class="mt-2 block text-sm text-brand-redDark"></span>
                </label>

                <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Chi nhánh</span>
                    <select asp-for="BranchId" class="input-field">
                        <option value="">Chọn chi nhánh</option>
                        @foreach (var branch in Model.Branches)
                        {
                            <option value="@branch.Id">@branch.Name - @branch.OpeningHours</option>
                        }
                    </select>
                    <span asp-validation-for="BranchId" class="mt-2 block text-sm text-brand-redDark"></span>
                </label>

                <div class="grid gap-4 sm:grid-cols-3">
                    <label class="block">
                        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Số lượng khách</span>
                        <input asp-for="GuestCount" type="number" min="1" max="100" class="input-field" />
                        <span asp-validation-for="GuestCount" class="mt-2 block text-sm text-brand-redDark"></span>
                    </label>

                    <label class="block">
                        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Ngày đến</span>
                        <input asp-for="ReservationDate" type="date" asp-format="{0:yyyy-MM-dd}" class="input-field" />
                        <span asp-validation-for="ReservationDate" class="mt-2 block text-sm text-brand-redDark"></span>
                    </label>

                    <label class="block">
                        <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Giờ đến</span>
                        <input asp-for="ReservationTime" type="time" asp-format="{0:HH:mm}" class="input-field" />
                        <span asp-validation-for="ReservationTime" class="mt-2 block text-sm text-brand-redDark"></span>
                    </label>
                </div>

                @if (Model.ShouldShowLargeGroupNotice)
                {
                    <div class="rounded-md border border-brand-gold/25 bg-brand-goldSoft/30 p-4 text-sm leading-6 text-brand-dark">
                        Nhóm trên 12 người nên gọi hotline <a href="tel:@Model.Hotline.Replace(" ", string.Empty)" class="font-black text-brand-goldDeep">@Model.Hotline</a> để xác nhận khu vực bàn phù hợp.
                    </div>
                }

                <label class="block">
                    <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Ghi chú</span>
                    <textarea asp-for="Note" rows="4" class="input-area" placeholder="Ví dụ: cần ghế trẻ em, sinh nhật, bàn yên tĩnh..."></textarea>
                    <span asp-validation-for="Note" class="mt-2 block text-sm text-brand-redDark"></span>
                </label>

                <button type="submit" class="btn-primary h-12 w-full sm:w-auto">Hoàn tất đặt bàn</button>
            </form>
        </div>

        <aside class="space-y-5">
            <div class="surface-panel p-5">
                <p class="text-kicker font-black uppercase text-brand-goldDeep">Gợi ý nhóm</p>
                <div class="mt-5 grid gap-3">
                    @foreach (var item in new[] { ("Đi 1-2 người", "Bàn nhỏ, phục vụ nhanh cho bữa ăn nhẹ."), ("Nhóm 3-6", "Phù hợp combo, món nướng và nhiều phần dùng chung."), ("Nhóm 7-12", "Nên đặt trước để sắp bàn nhóm thoải mái."), ("Trên 12 người", "Gọi hotline để xác nhận khu vực và thời gian.") })
                    {
                        <div class="surface-muted p-4">
                            <h3 class="font-black text-brand-dark">@item.Item1</h3>
                            <p class="mt-2 text-sm leading-6 text-brand-gray">@item.Item2</p>
                        </div>
                    }
                </div>
            </div>

            <div class="surface-panel p-5">
                <p class="text-kicker font-black uppercase text-brand-goldDeep">Chi nhánh</p>
                @if (Model.Branches.Count > 0)
                {
                    <div class="mt-4 space-y-3">
                        @foreach (var branch in Model.Branches.Take(3))
                        {
                            <div class="surface-muted p-4">
                                <h3 class="font-black text-brand-dark">@branch.Name</h3>
                                <p class="mt-2 text-sm leading-6 text-brand-gray">@branch.Address</p>
                                <p class="mt-2 text-sm font-semibold text-brand-goldDeep">@branch.OpeningHours</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="mt-4 text-sm leading-6 text-brand-gray">Danh sách chi nhánh sẽ hiển thị sau khi kết nối cơ sở dữ liệu.</p>
                }
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
