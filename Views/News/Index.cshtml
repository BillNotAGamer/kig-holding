@model NewsIndexViewModel

@{
    ViewData["Title"] = Model.SeoTitle;
    ViewData["MetaDescription"] = Model.SeoDescription;

    var allCategoriesActive = string.IsNullOrWhiteSpace(Model.SelectedCategorySlug);
    var featuredCount = Math.Min(Model.Posts.Count, 5);
    var secondaryStart = featuredCount > 0 ? 1 : 0;
    var secondaryCount = Math.Min(Math.Max(featuredCount - secondaryStart, 0), 2);
    var compactStart = secondaryStart + secondaryCount;
    var compactCount = Math.Max(featuredCount - compactStart, 0);
    var remainingStart = featuredCount;
    var remainingCount = Math.Max(Model.Posts.Count - remainingStart, 0);

    string BuildNewsUrl(string? categorySlug, int? page = null)
    {
        var query = new System.Collections.Generic.List<string>();

        if (!string.IsNullOrWhiteSpace(categorySlug))
        {
            query.Add($"category={Uri.EscapeDataString(categorySlug)}");
        }

        if (page.HasValue && page.Value > 1)
        {
            query.Add($"page={page.Value}");
        }

        return query.Count == 0
            ? "/tin-tuc"
            : $"/tin-tuc?{string.Join("&", query)}";
    }
}

<div class="news-index news-index--dark news-index--editorial relative isolate overflow-hidden pb-20 text-white" data-news-page="index">
    <section class="section-shell relative z-10">
        <div class="container-page relative z-10">
            <div class="mx-auto max-w-4xl rounded-[2rem] border border-white/10 bg-white/[0.03] px-6 py-10 text-center shadow-[0_28px_80px_rgba(0,0,0,0.22)] backdrop-blur sm:px-8 lg:px-12" data-uw-reveal="fade-up">
                <p class="text-kicker font-black uppercase tracking-[0.34em] text-brand-red">TIN TỨC &amp; CẬP NHẬT</p>
                <h1 class="public-page-title mt-5 text-white">
                    Tin mới từ Truyền Thuyết Champong
                </h1>
                <p class="mx-auto mt-5 max-w-3xl text-lead text-white/65">
                    Cập nhật thông tin nhượng quyền, hệ thống chi nhánh, sự kiện, ưu đãi và những món mới từ Truyền Thuyết Champong.
                </p>
            </div>

            <div class="news-index__filter-shell mt-10 flex flex-wrap gap-3 rounded-[1.6rem] border border-white/10 p-3 backdrop-blur" data-uw-reveal="fade-up" data-uw-delay="100">
                <a href="/tin-tuc"
                   class="inline-flex items-center justify-center rounded-full border px-4 py-2 text-sm font-semibold transition duration-200 @(allCategoriesActive ? "border-brand-red bg-brand-red text-white shadow-[0_14px_34px_rgba(229,9,20,0.24)]" : "border-white/10 bg-white/[0.04] text-white/75 hover:border-brand-red/60 hover:text-white")"
                   aria-current="@(allCategoriesActive ? "page" : null)">
                    Tất cả
                </a>
                @foreach (var category in Model.Categories)
                {
                    <a href="@BuildNewsUrl(category.Slug)"
                       class="inline-flex items-center justify-center rounded-full border px-4 py-2 text-sm font-semibold transition duration-200 @(category.IsActive ? "border-brand-red bg-brand-red text-white shadow-[0_14px_34px_rgba(229,9,20,0.24)]" : "border-white/10 bg-white/[0.04] text-white/75 hover:border-brand-red/60 hover:text-white")"
                       aria-current="@(category.IsActive ? "page" : null)">
                        @category.Name
                    </a>
                }
            </div>

            @if (Model.Posts.Count > 0)
            {
                <div class="mt-12 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between" data-uw-reveal="fade-up" data-uw-delay="150">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-white/45">Tổng quan chuyên mục</p>
                        <h2 class="mt-2 text-[clamp(2rem,3vw,2.8rem)] font-black leading-tight text-white">
                            @(string.IsNullOrWhiteSpace(Model.SelectedCategoryName) ? "Tất cả tin tức" : Model.SelectedCategoryName)
                        </h2>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 text-sm">
                        <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-white/72">
                            @Model.TotalItems bài viết
                        </span>
                        <span class="rounded-full border border-brand-red/20 bg-brand-red/10 px-4 py-2 text-brand-red">
                            @featuredCount nổi bật
                        </span>
                        @if (Model.TotalPages > 1)
                        {
                            <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-white/72">
                                Trang @Model.Page / @Model.TotalPages
                            </span>
                        }
                    </div>
                </div>

                <section class="mt-10" aria-labelledby="news-featured-heading">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between" data-uw-reveal="fade-up" data-uw-delay="180">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-red">Nổi bật</p>
                            <h3 id="news-featured-heading" class="mt-2 text-2xl font-black text-white sm:text-[2rem]">
                                Dòng tin nổi bật hôm nay
                            </h3>
                        </div>
                        <p class="max-w-2xl text-sm leading-7 text-white/60 sm:text-right">
                            Những bài viết quan trọng nhất được đặt ở đầu trang để tạo nhịp đọc rõ ràng hơn trước khi đi vào danh sách đầy đủ.
                        </p>
                    </div>

                    <div class="mt-8 grid gap-5 lg:grid-cols-12">
                        @if (featuredCount > 0)
                        {
                            var post = Model.Posts[0];

                            <article class="news-card news-feature-lead group lg:col-span-7 xl:col-span-8" data-uw-reveal="fade-up" data-uw-delay="220">
                                <a href="@post.Url" class="block h-full" aria-label="@post.Title">
                                    <div class="news-card__media news-feature-lead__media">
                                        <img src="@post.ImageUrl"
                                             alt="@post.Title"
                                             class="news-card__image"
                                             loading="lazy"
                                             onerror="this.remove();" />
                                        <div class="absolute inset-x-0 top-0 z-10 flex items-start justify-between gap-3 p-5 sm:p-6">
                                            <span class="inline-flex rounded-full bg-brand-red px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-white shadow-[0_12px_24px_rgba(229,9,20,0.22)]">
                                                @post.Category
                                            </span>
                                            @if (post.PublishedAt.HasValue)
                                            {
                                                <time datetime="@post.PublishedAt.Value.ToString("yyyy-MM-dd")"
                                                      class="rounded-full border border-white/15 bg-black/25 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-white/75 backdrop-blur">
                                                    @post.PublishedAt.Value.ToString("dd/MM/yyyy")
                                                </time>
                                            }
                                        </div>
                                    </div>

                                    <div class="p-6 sm:p-8">
                                        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/45">Bài dẫn đầu</p>
                                        <h2 class="mt-4 text-[clamp(2rem,3vw,3rem)] font-black leading-[1.02] text-white transition duration-200 group-hover:text-white/92">
                                            @post.Title
                                        </h2>
                                        <p class="mt-5 max-w-3xl line-clamp-4 text-base leading-8 text-white/68">
                                            @post.Excerpt
                                        </p>
                                        <span class="news-card__readmore mt-7 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-[0.14em] text-brand-red">
                                            Đọc tiếp
                                            <span aria-hidden="true">&rarr;</span>
                                        </span>
                                    </div>
                                </a>
                            </article>
                        }

                        @if (secondaryCount > 0)
                        {
                            <div class="grid gap-5 lg:col-span-5 xl:col-span-4">
                                @for (var index = secondaryStart; index < secondaryStart + secondaryCount; index++)
                                {
                                    var post = Model.Posts[index];
                                    var delay = 260 + ((index - secondaryStart) * 60);

                                    <article class="news-card news-feature-secondary group" data-uw-reveal="fade-up" data-uw-delay="@delay">
                                        <a href="@post.Url" class="block h-full" aria-label="@post.Title">
                                            <div class="news-card__media news-feature-secondary__media">
                                                <img src="@post.ImageUrl"
                                                     alt="@post.Title"
                                                     class="news-card__image"
                                                     loading="lazy"
                                                     onerror="this.remove();" />
                                                <div class="absolute left-4 top-4 z-10 rounded-full bg-brand-red px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-white shadow-[0_12px_24px_rgba(229,9,20,0.22)]">
                                                    @post.Category
                                                </div>
                                            </div>

                                            <div class="p-5 sm:p-6">
                                                @if (post.PublishedAt.HasValue)
                                                {
                                                    <time datetime="@post.PublishedAt.Value.ToString("yyyy-MM-dd")" class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/45">
                                                        @post.PublishedAt.Value.ToString("dd/MM/yyyy")
                                                    </time>
                                                }
                                                <h3 class="mt-3 text-[1.45rem] font-black leading-tight text-white transition duration-200 group-hover:text-white/92">
                                                    @post.Title
                                                </h3>
                                                <p class="mt-3 line-clamp-3 text-sm leading-7 text-white/62">
                                                    @post.Excerpt
                                                </p>
                                                <span class="news-card__readmore mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-red">
                                                    Đọc tiếp
                                                    <span aria-hidden="true">&rarr;</span>
                                                </span>
                                            </div>
                                        </a>
                                    </article>
                                }
                            </div>
                        }

                        @if (compactCount > 0)
                        {
                            <div class="grid gap-5 lg:col-span-12 md:grid-cols-2">
                                @for (var index = compactStart; index < compactStart + compactCount; index++)
                                {
                                    var post = Model.Posts[index];
                                    var delay = 360 + ((index - compactStart) * 60);

                                    <article class="news-card news-feature-compact group" data-uw-reveal="fade-up" data-uw-delay="@delay">
                                        <a href="@post.Url" class="block h-full sm:grid sm:grid-cols-[12rem_minmax(0,1fr)]" aria-label="@post.Title">
                                            <div class="news-card__media news-feature-compact__media">
                                                <img src="@post.ImageUrl"
                                                     alt="@post.Title"
                                                     class="news-card__image"
                                                     loading="lazy"
                                                     onerror="this.remove();" />
                                            </div>

                                            <div class="p-5 sm:p-6">
                                                <div class="flex flex-wrap items-center gap-2">
                                                    <span class="inline-flex rounded-full border border-brand-red/25 bg-brand-red/12 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.14em] text-brand-red">
                                                        @post.Category
                                                    </span>
                                                    @if (post.PublishedAt.HasValue)
                                                    {
                                                        <time datetime="@post.PublishedAt.Value.ToString("yyyy-MM-dd")" class="text-[11px] font-semibold uppercase tracking-[0.16em] text-white/45">
                                                            @post.PublishedAt.Value.ToString("dd/MM/yyyy")
                                                        </time>
                                                    }
                                                </div>
                                                <h3 class="mt-3 text-[1.28rem] font-black leading-tight text-white transition duration-200 group-hover:text-white/92">
                                                    @post.Title
                                                </h3>
                                                <p class="mt-3 line-clamp-2 text-sm leading-7 text-white/60">
                                                    @post.Excerpt
                                                </p>
                                                <span class="news-card__readmore mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-red">
                                                    Đọc tiếp
                                                    <span aria-hidden="true">&rarr;</span>
                                                </span>
                                            </div>
                                        </a>
                                    </article>
                                }
                            </div>
                        }
                    </div>
                </section>

                @if (remainingCount > 0)
                {
                    <section class="mt-16" aria-labelledby="news-latest-heading">
                        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between" data-uw-reveal="fade-up" data-uw-delay="420">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/45">Bài viết mới nhất</p>
                                <h3 id="news-latest-heading" class="mt-2 text-2xl font-black text-white sm:text-[2rem]">
                                    Các bài viết khác
                                </h3>
                            </div>
                            <span class="inline-flex items-center rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-white/70">
                                @remainingCount bài viết
                            </span>
                        </div>

                        <div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
                            @for (var index = remainingStart; index < Model.Posts.Count; index++)
                            {
                                var post = Model.Posts[index];
                                var delay = 460 + (((index - remainingStart) % 6) * 60);

                                <article class="news-card news-card-standard group" data-uw-reveal="fade-up" data-uw-delay="@delay">
                                    <a href="@post.Url" class="block h-full" aria-label="@post.Title">
                                        <div class="news-card__media news-card-standard__media">
                                            <img src="@post.ImageUrl"
                                                 alt="@post.Title"
                                                 class="news-card__image"
                                                 loading="lazy"
                                                 onerror="this.remove();" />
                                            <div class="absolute left-4 top-4 z-10 rounded-full bg-brand-red px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-white shadow-[0_12px_24px_rgba(229,9,20,0.22)]">
                                                @post.Category
                                            </div>
                                        </div>

                                        <div class="p-5 sm:p-6">
                                            @if (post.PublishedAt.HasValue)
                                            {
                                                <time datetime="@post.PublishedAt.Value.ToString("yyyy-MM-dd")" class="text-[11px] font-semibold uppercase tracking-[0.18em] text-white/45">
                                                    @post.PublishedAt.Value.ToString("dd/MM/yyyy")
                                                </time>
                                            }
                                            <h3 class="mt-3 text-[1.35rem] font-black leading-tight text-white transition duration-200 group-hover:text-white/92">
                                                @post.Title
                                            </h3>
                                            <p class="mt-4 line-clamp-3 text-sm leading-7 text-white/62">
                                                @post.Excerpt
                                            </p>
                                            <span class="news-card__readmore mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-red">
                                                Đọc tiếp
                                                <span aria-hidden="true">&rarr;</span>
                                            </span>
                                        </div>
                                    </a>
                                </article>
                            }
                        </div>
                    </section>
                }

                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-12 flex flex-wrap items-center justify-center gap-2 sm:gap-3" aria-label="Phân trang tin tức" data-uw-reveal="fade-up" data-uw-delay="520">
                        <a href="@BuildNewsUrl(Model.SelectedCategorySlug, Model.Page - 1)"
                           class="inline-flex min-w-[3.4rem] items-center justify-center rounded-full border px-4 py-2 text-sm font-semibold transition duration-200 @(Model.HasPreviousPage ? "border-white/10 bg-white/[0.04] text-white/70 hover:border-brand-red/50 hover:text-white" : "pointer-events-none border-white/10 bg-white/[0.04] text-white/35 opacity-40")"
                           aria-disabled="@(!Model.HasPreviousPage)">
                            Trước
                        </a>

                        @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                        {
                            <a href="@BuildNewsUrl(Model.SelectedCategorySlug, pageNumber)"
                               class="inline-flex size-11 items-center justify-center rounded-full border text-sm font-semibold transition duration-200 @(pageNumber == Model.Page ? "border-brand-red bg-brand-red text-white shadow-[0_14px_34px_rgba(229,9,20,0.24)]" : "border-white/10 bg-white/[0.04] text-white/70 hover:border-brand-red/50 hover:text-white")"
                               aria-current="@(pageNumber == Model.Page ? "page" : null)">
                                @pageNumber
                            </a>
                        }

                        <a href="@BuildNewsUrl(Model.SelectedCategorySlug, Model.Page + 1)"
                           class="inline-flex min-w-[3.4rem] items-center justify-center rounded-full border px-4 py-2 text-sm font-semibold transition duration-200 @(Model.HasNextPage ? "border-white/10 bg-white/[0.04] text-white/70 hover:border-brand-red/50 hover:text-white" : "pointer-events-none border-white/10 bg-white/[0.04] text-white/35 opacity-40")"
                           aria-disabled="@(!Model.HasNextPage)">
                            Sau
                        </a>
                    </nav>
                }
            }
            else
            {
                <div class="mx-auto mt-12 max-w-3xl rounded-[1.6rem] border border-white/10 bg-white/[0.04] p-8 text-center shadow-panel backdrop-blur sm:p-10" data-uw-reveal="fade-up" data-uw-delay="160">
                    <p class="text-kicker font-black uppercase tracking-[0.22em] text-brand-red">Chưa có nội dung</p>
                    <h2 class="mt-4 text-3xl font-black text-white">Chưa có bài viết phù hợp với bộ lọc hiện tại.</h2>
                    <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-white/65">
                        Hãy quay lại tất cả tin tức để tiếp tục xem các cập nhật mới nhất từ Truyền Thuyết Champong.
                    </p>
                    <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
                        <a href="/tin-tuc" class="inline-flex items-center justify-center rounded-full bg-brand-red px-6 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-white shadow-[0_16px_34px_rgba(229,9,20,0.24)] transition duration-200 hover:bg-brand-redDark">
                            Xem tất cả tin tức
                        </a>
                        <a href="/lien-he" class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/[0.04] px-6 py-3 text-sm font-semibold uppercase tracking-[0.16em] text-white/80 transition duration-200 hover:border-brand-red/60 hover:text-white">
                            Liên hệ
                        </a>
                    </div>
                </div>
            }
        </div>
    </section>
</div>
