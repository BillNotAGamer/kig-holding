@model KIGHolding.Areas.Admin.ViewModels.PostIndexViewModel

@{
    ViewData["Title"] = "Quản lý bài viết";

    var paginationStart = Math.Max(1, Model.Page - 2);
    var paginationEnd = Math.Min(Model.TotalPages, Model.Page + 2);

    if (Model.TotalPages > 0 && paginationEnd - paginationStart < 4)
    {
        if (paginationStart == 1)
        {
            paginationEnd = Math.Min(Model.TotalPages, paginationStart + 4);
        }
        else if (paginationEnd == Model.TotalPages)
        {
            paginationStart = Math.Max(1, paginationEnd - 4);
        }
    }
}

<section class="space-y-6">
    <div class="surface-panel flex flex-col gap-5 p-6 sm:p-7 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
            <p class="text-xs font-black uppercase tracking-[0.24em] text-brand-red">POSTS</p>
            <h1 class="mt-3 text-3xl font-black tracking-tight text-brand-dark">Quản lý bài viết</h1>
            <p class="mt-3 text-sm leading-7 text-brand-gray">
                Tìm kiếm, lọc và quản lý các bài viết hiển thị trên trang tin tức.
            </p>
        </div>

        <a asp-action="Create" class="btn-primary">
            Tạo bài viết mới
        </a>
    </div>

    <form method="get" asp-action="Index" class="surface-panel p-6 sm:p-7">
        <div class="grid gap-4 xl:grid-cols-[minmax(0,1.6fr)_minmax(0,0.95fr)_minmax(0,0.85fr)_auto_auto] xl:items-end">
            <div>
                <label for="q" class="admin-post-label">Tìm kiếm</label>
                <input id="q"
                       name="q"
                       type="search"
                       value="@Model.SearchQuery"
                       class="admin-post-field"
                       placeholder="Tiêu đề, slug, excerpt, SEO title..." />
            </div>

            <div>
                <label for="category" class="admin-post-label">Danh mục</label>
                <select id="category" name="category" class="admin-post-field">
                    <option value="">Tất cả danh mục</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Value" selected="@(Model.SelectedCategory == category.Value ? "selected" : null)">
                            @category.Label
                        </option>
                    }
                </select>
            </div>

            <div>
                <label for="status" class="admin-post-label">Trạng thái</label>
                <select id="status" name="status" class="admin-post-field">
                    @foreach (var status in Model.StatusOptions)
                    {
                        var isSelected = (string.IsNullOrWhiteSpace(Model.SelectedStatus) && status.Value == "all")
                            || Model.SelectedStatus == status.Value;

                        <option value="@(status.Value == "all" ? string.Empty : status.Value)" selected="@(isSelected ? "selected" : null)">
                            @status.Label
                        </option>
                    }
                </select>
            </div>

            <button type="submit" class="btn-primary h-12">
                Lọc
            </button>

            <a asp-action="Index" class="btn-secondary h-12">
                Xóa lọc
            </a>
        </div>
    </form>

    <div class="surface-panel overflow-hidden">
        <div class="border-b border-brand-border bg-brand-light/60 px-6 py-4 sm:px-7">
            @if (Model.TotalItems > 0)
            {
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <p class="text-sm font-semibold text-brand-dark">
                        Hiển thị @Model.FirstItemIndex–@Model.LastItemIndex trong @Model.TotalItems bài viết
                    </p>
                    <p class="text-sm text-brand-gray">
                        Trang @Model.Page / @(Model.TotalPages == 0 ? 1 : Model.TotalPages)
                    </p>
                </div>
            }
            else
            {
                <p class="text-sm font-semibold text-brand-dark">
                    Không tìm thấy bài viết phù hợp.
                </p>
            }
        </div>

        @if (Model.Posts.Count > 0)
        {
            <div class="grid gap-4 p-4 md:p-6 lg:hidden">
                @foreach (var post in Model.Posts)
                {
                    var excerptPreview = string.IsNullOrWhiteSpace(post.Excerpt)
                        ? string.Empty
                        : post.Excerpt.Length > 130 ? $"{post.Excerpt[..130]}..." : post.Excerpt;

                    <article class="rounded-3xl border border-brand-border bg-white p-5 shadow-soft">
                        <div class="flex gap-4">
                            @if (!string.IsNullOrWhiteSpace(post.ThumbnailUrl))
                            {
                                <img src="@post.ThumbnailUrl" alt="@post.Title" class="h-20 w-24 shrink-0 rounded-2xl border border-brand-border object-cover" />
                            }
                            else
                            {
                                <div class="grid h-20 w-24 shrink-0 place-items-center rounded-2xl border border-dashed border-brand-border bg-brand-light text-center text-[11px] font-semibold uppercase tracking-[0.12em] text-brand-gray">
                                    No image
                                </div>
                            }

                            <div class="min-w-0 flex-1">
                                <div class="flex flex-wrap items-center gap-2">
                                    <span class="rounded-full border border-brand-border bg-brand-light px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-brand-gray">
                                        @post.CategoryDisplayName
                                    </span>
                                    @if (post.IsPublished)
                                    {
                                        <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-emerald-700">
                                            Đã đăng
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="rounded-full border border-slate-200 bg-slate-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-600">
                                            Bản nháp
                                        </span>
                                    }
                                </div>

                                <h2 class="mt-3 text-lg font-black leading-tight text-brand-dark">@post.Title</h2>
                                <p class="mt-1 text-xs text-brand-gray">@post.Slug</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(excerptPreview))
                        {
                            <p class="mt-4 text-sm leading-7 text-brand-gray">
                                @excerptPreview
                            </p>
                        }

                        <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
                            <div>
                                <dt class="text-[11px] font-semibold uppercase tracking-[0.14em] text-brand-gray">Ngày đăng</dt>
                                <dd class="mt-1 text-brand-dark">@((post.PublishedAt.HasValue) ? post.PublishedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "Chưa có")</dd>
                            </div>
                            <div>
                                <dt class="text-[11px] font-semibold uppercase tracking-[0.14em] text-brand-gray">Cập nhật</dt>
                                <dd class="mt-1 text-brand-dark">@post.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
                            </div>
                        </dl>

                        <div class="mt-5 flex flex-wrap gap-3">
                            @if (post.IsPublished && !string.IsNullOrWhiteSpace(post.PublicUrl))
                            {
                                <a href="@post.PublicUrl"
                                   target="_blank"
                                   rel="noopener"
                                   class="inline-flex items-center justify-center rounded-full border border-brand-border bg-brand-light px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand-dark transition hover:border-brand-red hover:text-brand-red">
                                    Xem công khai
                                </a>
                            }

                            <a asp-action="Edit"
                               asp-route-id="@post.Id"
                               class="inline-flex items-center justify-center rounded-full border border-brand-border bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand-dark transition hover:border-brand-red hover:text-brand-red">
                                Sửa
                            </a>

                            <form asp-action="Delete"
                                  asp-route-id="@post.Id"
                                  asp-route-q="@Model.SearchQuery"
                                  asp-route-category="@Model.SelectedCategory"
                                  asp-route-status="@Model.SelectedStatus"
                                  asp-route-page="@Model.Page"
                                  method="post"
                                  class="inline"
                                  onsubmit="return confirm('Ẩn bài viết này khỏi website công khai?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="inline-flex items-center justify-center rounded-full border border-brand-red/20 bg-brand-red/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand-redDark transition hover:border-brand-red hover:bg-brand-red hover:text-white">
                                    Ẩn bài
                                </button>
                            </form>
                        </div>
                    </article>
                }
            </div>

            <div class="hidden overflow-x-auto lg:block">
                <table class="min-w-full text-left text-sm text-brand-gray">
                    <thead class="border-b border-brand-border bg-brand-light text-xs uppercase tracking-[0.14em] text-brand-dark">
                        <tr>
                            <th class="px-6 py-4 font-semibold">Thumbnail</th>
                            <th class="px-6 py-4 font-semibold">Bài viết</th>
                            <th class="px-6 py-4 font-semibold">Danh mục</th>
                            <th class="px-6 py-4 font-semibold">Trạng thái</th>
                            <th class="px-6 py-4 font-semibold">Ngày đăng</th>
                            <th class="px-6 py-4 font-semibold">Cập nhật</th>
                            <th class="px-6 py-4 font-semibold">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-brand-border">
                        @foreach (var post in Model.Posts)
                        {
                            var excerptPreview = string.IsNullOrWhiteSpace(post.Excerpt)
                                ? string.Empty
                                : post.Excerpt.Length > 110 ? $"{post.Excerpt[..110]}..." : post.Excerpt;

                            <tr class="align-top transition-colors hover:bg-brand-light/35">
                                <td class="px-6 py-5">
                                    @if (!string.IsNullOrWhiteSpace(post.ThumbnailUrl))
                                    {
                                        <img src="@post.ThumbnailUrl" alt="@post.Title" class="h-14 w-24 rounded-2xl border border-brand-border object-cover" />
                                    }
                                    else
                                    {
                                        <div class="grid h-14 w-24 place-items-center rounded-2xl border border-dashed border-brand-border bg-brand-light text-center text-[11px] font-semibold uppercase tracking-[0.12em] text-brand-gray">
                                            No image
                                        </div>
                                    }
                                </td>
                                <td class="px-6 py-5">
                                    <div class="max-w-[24rem]">
                                        <p class="text-base font-bold leading-tight text-brand-dark">@post.Title</p>
                                        <p class="mt-1 text-xs text-brand-gray">@post.Slug</p>
                                        @if (!string.IsNullOrWhiteSpace(excerptPreview))
                                        {
                                            <p class="mt-3 text-sm leading-6 text-brand-gray">@excerptPreview</p>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <span class="inline-flex rounded-full border border-brand-border bg-brand-light px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-brand-gray">
                                        @post.CategoryDisplayName
                                    </span>
                                </td>
                                <td class="px-6 py-5">
                                    @if (post.IsPublished)
                                    {
                                        <span class="inline-flex rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-emerald-700">
                                            Đã đăng
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex rounded-full border border-slate-200 bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-slate-600">
                                            Bản nháp
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-5 text-brand-dark">
                                    @((post.PublishedAt.HasValue) ? post.PublishedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "Chưa có")
                                </td>
                                <td class="px-6 py-5 text-brand-dark">
                                    @post.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="px-6 py-5">
                                    <div class="flex flex-col items-start gap-2">
                                        @if (post.IsPublished && !string.IsNullOrWhiteSpace(post.PublicUrl))
                                        {
                                            <a href="@post.PublicUrl"
                                               target="_blank"
                                               rel="noopener"
                                               class="inline-flex items-center justify-center rounded-full border border-brand-border bg-brand-light px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand-dark transition hover:border-brand-red hover:text-brand-red">
                                                Xem công khai
                                            </a>
                                        }

                                        <a asp-action="Edit"
                                           asp-route-id="@post.Id"
                                           class="inline-flex items-center justify-center rounded-full border border-brand-border bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand-dark transition hover:border-brand-red hover:text-brand-red">
                                            Sửa
                                        </a>

                                        <form asp-action="Delete"
                                              asp-route-id="@post.Id"
                                              asp-route-q="@Model.SearchQuery"
                                              asp-route-category="@Model.SelectedCategory"
                                              asp-route-status="@Model.SelectedStatus"
                                              asp-route-page="@Model.Page"
                                              method="post"
                                              class="inline"
                                              onsubmit="return confirm('Ẩn bài viết này khỏi website công khai?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="inline-flex items-center justify-center rounded-full border border-brand-red/20 bg-brand-red/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-brand-redDark transition hover:border-brand-red hover:bg-brand-red hover:text-white">
                                                Ẩn bài
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-8 sm:p-10">
                <div class="rounded-3xl border border-dashed border-brand-border bg-brand-light/60 p-8 text-center">
                    <h2 class="text-2xl font-black text-brand-dark">Không có bài viết phù hợp</h2>
                    <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-brand-gray">
                        Hãy điều chỉnh bộ lọc, xóa từ khóa tìm kiếm hoặc tạo bài viết mới để bổ sung nội dung cho trang tin tức.
                    </p>
                    <div class="mt-6 flex flex-wrap justify-center gap-3">
                        <a asp-action="Index" class="btn-secondary">
                            Xóa lọc
                        </a>
                        <a asp-action="Create" class="btn-primary">
                            Tạo bài viết mới
                        </a>
                    </div>
                </div>
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <div class="border-t border-brand-border px-4 py-4 sm:px-6">
                <div class="flex flex-wrap items-center justify-between gap-3">
                    <a asp-action="Index"
                       asp-route-q="@Model.SearchQuery"
                       asp-route-category="@Model.SelectedCategory"
                       asp-route-status="@Model.SelectedStatus"
                       asp-route-page="@(Model.Page - 1)"
                       class="inline-flex items-center justify-center rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] transition @(Model.HasPreviousPage ? "border-brand-border bg-white text-brand-dark hover:border-brand-red hover:text-brand-red" : "pointer-events-none border-brand-border/70 bg-brand-light text-brand-gray/60")">
                        Trang trước
                    </a>

                    <div class="flex flex-wrap items-center justify-center gap-2">
                        @for (var currentPage = paginationStart; currentPage <= paginationEnd; currentPage++)
                        {
                            var isActive = currentPage == Model.Page;

                            <a asp-action="Index"
                               asp-route-q="@Model.SearchQuery"
                               asp-route-category="@Model.SelectedCategory"
                               asp-route-status="@Model.SelectedStatus"
                               asp-route-page="@currentPage"
                               class="inline-flex h-10 min-w-10 items-center justify-center rounded-full border px-3 text-sm font-semibold transition @(isActive ? "border-brand-red bg-brand-red text-white shadow-soft" : "border-brand-border bg-white text-brand-dark hover:border-brand-red hover:text-brand-red")">
                                @currentPage
                            </a>
                        }
                    </div>

                    <a asp-action="Index"
                       asp-route-q="@Model.SearchQuery"
                       asp-route-category="@Model.SelectedCategory"
                       asp-route-status="@Model.SelectedStatus"
                       asp-route-page="@(Model.Page + 1)"
                       class="inline-flex items-center justify-center rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] transition @(Model.HasNextPage ? "border-brand-border bg-white text-brand-dark hover:border-brand-red hover:text-brand-red" : "pointer-events-none border-brand-border/70 bg-brand-light text-brand-gray/60")">
                        Trang sau
                    </a>
                </div>
            </div>
        }
    </div>
</section>
