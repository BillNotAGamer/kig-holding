@model KIGHolding.Areas.Admin.ViewModels.PostEditViewModel

@{
    ViewData["Title"] = "Sửa bài viết";
}

<section class="space-y-6">
    <div class="surface-panel p-6">
        <p class="text-kicker font-black uppercase text-brand-goldDeep">Posts</p>
        <h2 class="mt-2 text-2xl font-black text-brand-dark">Chỉnh sửa bài viết</h2>

        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="mt-6 space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-sm text-brand-redDark"></div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="Title" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Title" class="form-input" />
                    <span asp-validation-for="Title" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="Slug" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Slug" class="form-input" />
                    <span asp-validation-for="Slug" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
            </div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="Category" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <select asp-for="Category" asp-items="Model.CategoryOptions" class="form-input"></select>
                    <span asp-validation-for="Category" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="PublishedAt" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="PublishedAt" type="datetime-local" class="form-input" />
                    <span asp-validation-for="PublishedAt" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
            </div>

            <div>
                <label asp-for="Excerpt" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                <textarea asp-for="Excerpt" rows="3" class="form-input"></textarea>
                <span asp-validation-for="Excerpt" class="mt-2 block text-xs text-brand-redDark"></span>
            </div>

            <div>
                <label asp-for="Content" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                <textarea asp-for="Content" rows="10" class="form-input"></textarea>
                <span asp-validation-for="Content" class="mt-2 block text-xs text-brand-redDark"></span>
            </div>

            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="SeoTitle" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="SeoTitle" class="form-input" />
                </div>
                <div class="lg:col-span-2">
                    <label asp-for="SeoDescription" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="SeoDescription" class="form-input" />
                </div>
            </div>

            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="ThumbnailFile" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="ThumbnailFile" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-input" />
                    <span asp-validation-for="ThumbnailFile" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div class="lg:col-span-2 flex items-end gap-5">
                    <label class="flex items-center gap-3 text-sm text-brand-dark">
                        <input asp-for="IsPublished" type="checkbox" class="size-4 rounded border-brand-border text-brand-goldDeep" />
                        <span>Đăng công khai</span>
                    </label>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ExistingThumbnailUrl))
            {
                <div class="rounded-md border border-brand-border bg-brand-light p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray">Ảnh hiện tại</p>
                    <img src="@Model.ExistingThumbnailUrl" alt="@Model.Title" class="mt-3 h-28 w-44 rounded-md border border-brand-border object-cover" />
                </div>
            }

            <div class="flex flex-col gap-3 sm:flex-row">
                <button type="submit" class="btn-primary">Lưu thay đổi</button>
                <a asp-action="Index" class="btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
