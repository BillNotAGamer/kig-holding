@model KIGHolding.Areas.Admin.ViewModels.PostCreateViewModel

@{
    ViewData["Title"] = "Tạo bài viết";
}

<section class="space-y-6">
    <div class="surface-panel p-6">
        <p class="text-kicker font-black uppercase text-brand-goldDeep">Posts</p>
        <h2 class="mt-2 text-2xl font-black text-brand-dark">Tạo bài viết mới</h2>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="mt-6 space-y-6">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="admin-post-summary"></div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="Title" class="admin-post-label"></label>
                    <input asp-for="Title" class="admin-post-field" />
                    <span asp-validation-for="Title" class="admin-post-validation"></span>
                </div>
                <div>
                    <label asp-for="Slug" class="admin-post-label"></label>
                    <input asp-for="Slug" class="admin-post-field" />
                    <span asp-validation-for="Slug" class="admin-post-validation"></span>
                </div>
            </div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="Category" class="admin-post-label"></label>
                    <select asp-for="Category" asp-items="Model.CategoryOptions" class="admin-post-field"></select>
                    <span asp-validation-for="Category" class="admin-post-validation"></span>
                </div>
                <div>
                    <label asp-for="PublishedAt" class="admin-post-label"></label>
                    <input asp-for="PublishedAt" type="datetime-local" class="admin-post-field" />
                    <span asp-validation-for="PublishedAt" class="admin-post-validation"></span>
                </div>
            </div>

            <div>
                <label asp-for="Excerpt" class="admin-post-label"></label>
                <textarea asp-for="Excerpt" rows="3" class="admin-post-area min-h-32"></textarea>
                <span asp-validation-for="Excerpt" class="admin-post-validation"></span>
            </div>

            <div>
                <label asp-for="Content" class="admin-post-label"></label>
                <textarea asp-for="Content" rows="10" class="admin-post-area min-h-56" placeholder="Nhập nội dung HTML hoặc markdown đã được chuẩn bị sẵn..."></textarea>
                <span asp-validation-for="Content" class="admin-post-validation"></span>
            </div>

            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="SeoTitle" class="admin-post-label"></label>
                    <input asp-for="SeoTitle" class="admin-post-field" />
                </div>
                <div class="lg:col-span-2">
                    <label asp-for="SeoDescription" class="admin-post-label"></label>
                    <input asp-for="SeoDescription" class="admin-post-field" />
                </div>
            </div>

            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="ThumbnailFile" class="admin-post-label"></label>
                    <input asp-for="ThumbnailFile" type="file" accept=".jpg,.jpeg,.png,.webp" class="admin-post-file" />
                    <span asp-validation-for="ThumbnailFile" class="admin-post-validation"></span>
                </div>
                <div class="lg:col-span-2 flex items-end gap-5">
                    <label class="admin-post-checkbox-shell">
                        <input asp-for="IsPublished" type="checkbox" class="admin-post-checkbox" />
                        <span>Đăng công khai</span>
                    </label>
                </div>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row">
                <button type="submit" class="btn-primary">Lưu bài viết</button>
                <a asp-action="Index" class="btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
