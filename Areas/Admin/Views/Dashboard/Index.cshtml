@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<section class="space-y-6" data-admin-page="dashboard">
    <div class="surface-panel p-6 sm:p-8">
        <p class="text-kicker font-black uppercase text-brand-goldDeep">Welcome</p>
        <h2 class="mt-3 text-3xl font-black text-brand-dark">Xin chào, @Model.AdminUsername.</h2>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-brand-gray">
            Đây là nền tảng xác thực đầu tiên cho Admin Area. Dashboard hiện hiển thị các thống kê cơ bản và chuẩn bị cho quản lý Chi nhánh trong phase tiếp theo.
        </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <article class="surface-panel p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Tổng chi nhánh</p>
            <p class="mt-3 text-3xl font-black text-brand-dark">@Model.TotalBranches</p>
        </article>
        <article class="surface-panel p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Chi nhánh hoạt động</p>
            <p class="mt-3 text-3xl font-black text-brand-dark">@Model.ActiveBranches</p>
        </article>
        <article class="surface-panel p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Bài viết</p>
            <p class="mt-3 text-3xl font-black text-brand-dark">@Model.TotalPosts</p>
        </article>
        <article class="surface-panel p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-brand-goldDeep">Tin nhắn / Đặt bàn</p>
            <p class="mt-3 text-3xl font-black text-brand-dark">@(Model.TotalMessages + Model.PendingReservations)</p>
        </article>
    </div>

    <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
        <div class="surface-panel p-6">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <p class="text-kicker font-black uppercase text-brand-goldDeep">Tiếp theo</p>
                    <h3 class="mt-3 text-2xl font-black text-brand-dark">Quản lý Chi nhánh</h3>
                </div>
                <a href="/Admin/Branch" class="btn-primary">Mở module</a>
            </div>
            <p class="mt-4 text-sm leading-7 text-brand-gray">
                Module Branch đã có nền tảng CRUD và hiện được bảo vệ bằng cookie authentication. Các module khác có thể bám theo cùng `AdminBaseController`.
            </p>
        </div>

        <div class="surface-panel p-6">
            <p class="text-kicker font-black uppercase text-brand-goldDeep">Trạng thái hệ thống</p>
            <div class="mt-4 rounded-md border border-brand-border bg-brand-light p-4">
                <p class="font-semibold text-brand-dark">Kết nối dữ liệu</p>
                <p class="mt-2 text-sm leading-6 text-brand-gray">
                    @(Model.DatabaseConnected
                        ? "Database đã kết nối và dashboard đang đọc số liệu thực tế."
                        : "Database chưa cấu hình hoặc chưa truy cập được. Dashboard đang hiển thị số liệu placeholder an toàn.")
                </p>
            </div>
        </div>
    </div>
</section>
