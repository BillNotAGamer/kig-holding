@model KIGHolding.Areas.Admin.ViewModels.MenuItemIndexViewModel

@{
    ViewData["Title"] = "Món ăn";
}

<section class="space-y-6">
    <div class="surface-panel flex flex-col gap-4 p-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
            <p class="text-kicker font-black uppercase text-brand-goldDeep">Menu Items</p>
            <h2 class="mt-2 text-2xl font-black text-brand-dark">Món ăn</h2>
            <p class="mt-2 text-sm leading-6 text-brand-gray">Quản lý các món ăn trong hệ thống thực đơn hiện tại.</p>
        </div>

        <form method="get" class="flex flex-col gap-3 sm:flex-row sm:items-end">
            <div>
                <label class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray">Danh mục</label>
                <select asp-for="CategoryFilter" asp-items="Model.CategoryOptions" class="form-input"></select>
            </div>
            <div class="flex gap-3">
                <button type="submit" class="btn-primary">Lọc dữ liệu</button>
                <a asp-action="Index" class="btn-secondary">Xóa lọc</a>
            </div>
        </form>
    </div>

    <div class="overflow-hidden rounded-md border border-brand-border bg-white shadow-soft">
        <div class="overflow-x-auto">
            <table class="min-w-full text-left text-sm text-brand-gray">
                <thead class="border-b border-brand-border bg-brand-light text-xs uppercase text-brand-dark">
                    <tr>
                        <th class="px-6 py-4 font-semibold">Thumbnail</th>
                        <th class="px-6 py-4 font-semibold">Name</th>
                        <th class="px-6 py-4 font-semibold">Category</th>
                        <th class="px-6 py-4 font-semibold">Price</th>
                        <th class="px-6 py-4 font-semibold">Availability</th>
                        <th class="px-6 py-4 font-semibold">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-brand-border">
                    @foreach (var item in Model.Items)
                    {
                        <tr class="align-top transition-colors hover:bg-brand-light/50">
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrWhiteSpace(item.ThumbnailUrl))
                                {
                                    <img src="@item.ThumbnailUrl" alt="@item.Name" class="h-12 w-20 rounded-md border border-brand-border object-cover" />
                                }
                                else
                                {
                                    <div class="grid h-12 w-20 place-items-center rounded-md border border-brand-border bg-brand-light text-xs font-semibold text-brand-gray">No image</div>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <p class="font-semibold text-brand-dark">@item.Name</p>
                            </td>
                            <td class="px-6 py-4">@item.CategoryName</td>
                            <td class="px-6 py-4 font-semibold text-brand-dark">@item.Price.ToString("N0")đ</td>
                            <td class="px-6 py-4">
                                @if (item.IsAvailable)
                                {
                                    <span class="rounded-button border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">Đang hiển thị</span>
                                }
                                else
                                {
                                    <span class="rounded-button border border-slate-200 bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">Đã ẩn</span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-wrap gap-3">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="font-semibold text-brand-goldDeep transition hover:text-brand-dark">Sửa</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline" onsubmit="return confirm('Ẩn món ăn này khỏi website công khai?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="font-semibold text-brand-redDark transition hover:text-brand-red">Ẩn</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="p-8 text-center text-brand-gray">Chưa có món ăn nào.</div>
        }
    </div>
</section>
