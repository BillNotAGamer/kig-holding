@model KIGHolding.Areas.Admin.ViewModels.MenuItemCreateViewModel

@{
    ViewData["Title"] = "Tạo món ăn";
}

<section class="space-y-6">
    <div class="surface-panel p-6">
        <p class="text-kicker font-black uppercase text-brand-goldDeep">Menu Items</p>
        <h2 class="mt-2 text-2xl font-black text-brand-dark">Tạo món ăn mới</h2>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="mt-6 space-y-6">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-sm text-brand-redDark"></div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="CategoryId" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-input"></select>
                    <span asp-validation-for="CategoryId" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="Slug" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Slug" class="form-input" />
                    <span asp-validation-for="Slug" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
            </div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="Name" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Name" class="form-input" />
                    <span asp-validation-for="Name" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="KoreanName" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="KoreanName" class="form-input" />
                </div>
            </div>

            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="Price" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Price" type="number" step="0.01" class="form-input" />
                    <span asp-validation-for="Price" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="OriginalPrice" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="OriginalPrice" type="number" step="0.01" class="form-input" />
                </div>
                <div>
                    <label asp-for="DisplayOrder" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="DisplayOrder" type="number" class="form-input" />
                    <span asp-validation-for="DisplayOrder" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
            </div>

            <div>
                <label asp-for="ShortDescription" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                <textarea asp-for="ShortDescription" rows="3" class="form-input"></textarea>
                <span asp-validation-for="ShortDescription" class="mt-2 block text-xs text-brand-redDark"></span>
            </div>

            <div>
                <label asp-for="Description" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                <textarea asp-for="Description" rows="5" class="form-input"></textarea>
            </div>

            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="ThumbnailFile" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="ThumbnailFile" type="file" accept=".jpg,.jpeg,.png,.webp" class="form-input" />
                    <span asp-validation-for="ThumbnailFile" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="SpicyLevel" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="SpicyLevel" type="number" min="0" max="5" class="form-input" />
                    <span asp-validation-for="SpicyLevel" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="Calories" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Calories" type="number" min="0" class="form-input" />
                </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                <label class="flex items-center gap-3 text-sm text-brand-dark">
                    <input asp-for="IsSignature" type="checkbox" class="size-4 rounded border-brand-border text-brand-goldDeep" />
                    <span>Signature</span>
                </label>
                <label class="flex items-center gap-3 text-sm text-brand-dark">
                    <input asp-for="IsBestSeller" type="checkbox" class="size-4 rounded border-brand-border text-brand-goldDeep" />
                    <span>Best seller</span>
                </label>
                <label class="flex items-center gap-3 text-sm text-brand-dark">
                    <input asp-for="IsNew" type="checkbox" class="size-4 rounded border-brand-border text-brand-goldDeep" />
                    <span>New</span>
                </label>
                <label class="flex items-center gap-3 text-sm text-brand-dark">
                    <input asp-for="IsCombo" type="checkbox" class="size-4 rounded border-brand-border text-brand-goldDeep" />
                    <span>Combo</span>
                </label>
            </div>

            <label class="flex items-center gap-3 text-sm text-brand-dark">
                <input asp-for="IsAvailable" type="checkbox" class="size-4 rounded border-brand-border text-brand-goldDeep" />
                <span>Hiển thị công khai</span>
            </label>

            <div class="flex flex-col gap-3 sm:flex-row">
                <button type="submit" class="btn-primary">Lưu món ăn</button>
                <a asp-action="Index" class="btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
