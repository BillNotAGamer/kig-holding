@model KIGHolding.Areas.Admin.ViewModels.SettingViewModel

@{
    ViewData["Title"] = "Cấu hình Website";
}

<section class="space-y-6">
    <div class="surface-panel p-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="text-kicker font-black uppercase text-brand-goldDeep">Site Settings</p>
                <h2 class="mt-2 text-2xl font-black text-brand-dark">Cấu hình Website</h2>
                <p class="mt-2 text-sm leading-6 text-brand-gray">Cập nhật thông tin thương hiệu, liên hệ và vị trí hiển thị công khai.</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="mt-5 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                @successMessage
            </div>
        }

        <form asp-action="Update" method="post" class="mt-6 space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-sm text-brand-redDark"></div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="BrandName" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="BrandName" class="form-input" />
                    <span asp-validation-for="BrandName" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="Hotline" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Hotline" class="form-input" />
                    <span asp-validation-for="Hotline" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
            </div>

            <div>
                <label asp-for="Slogan" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                <textarea asp-for="Slogan" rows="3" class="form-input"></textarea>
                <span asp-validation-for="Slogan" class="mt-2 block text-xs text-brand-redDark"></span>
            </div>

            <div class="grid gap-5 lg:grid-cols-2">
                <div>
                    <label asp-for="Email" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Email" class="form-input" />
                    <span asp-validation-for="Email" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="Address" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="Address" class="form-input" />
                    <span asp-validation-for="Address" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
            </div>

            <div>
                <label asp-for="GoogleMapUrl" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                <input asp-for="GoogleMapUrl" class="form-input" />
                <span asp-validation-for="GoogleMapUrl" class="mt-2 block text-xs text-brand-redDark"></span>
            </div>

            <div class="grid gap-5 lg:grid-cols-3">
                <div>
                    <label asp-for="FacebookUrl" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="FacebookUrl" class="form-input" />
                    <span asp-validation-for="FacebookUrl" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="ZaloUrl" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="ZaloUrl" class="form-input" />
                    <span asp-validation-for="ZaloUrl" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
                <div>
                    <label asp-for="TiktokUrl" class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-brand-gray"></label>
                    <input asp-for="TiktokUrl" class="form-input" />
                    <span asp-validation-for="TiktokUrl" class="mt-2 block text-xs text-brand-redDark"></span>
                </div>
            </div>

            <div class="flex justify-end">
                <button type="submit" class="btn-primary">Lưu cấu hình</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
