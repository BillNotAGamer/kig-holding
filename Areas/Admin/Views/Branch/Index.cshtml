@model IEnumerable<KIGHolding.Models.Entities.Branch>

@{
    ViewData["Title"] = "Quản lý Chi nhánh";
}

<section class="space-y-6">
    <div class="surface-panel flex flex-col gap-4 p-6 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <p class="text-kicker font-black uppercase text-brand-goldDeep">Branch CRUD</p>
            <h2 class="mt-2 text-2xl font-black text-brand-dark">Danh sách chi nhánh</h2>
            <p class="mt-2 text-sm leading-6 text-brand-gray">Quản lý thông tin địa chỉ, ảnh, hotline, trạng thái công khai và vị trí hiển thị trên trang `/chi-nhanh`.</p>
        </div>
        <a href="@Url.Action("Create")" class="btn-primary">Tạo chi nhánh mới</a>
    </div>

    <div class="overflow-hidden rounded-md border border-brand-border bg-white shadow-soft">
        <div class="overflow-x-auto">
            <table class="min-w-full text-left text-sm text-brand-gray">
                <thead class="border-b border-brand-border bg-brand-light text-xs uppercase text-brand-dark">
                    <tr>
                        <th class="px-6 py-4 font-semibold">Image</th>
                        <th class="px-6 py-4 font-semibold">Name</th>
                        <th class="px-6 py-4 font-semibold">City</th>
                        <th class="px-6 py-4 font-semibold">Hotline</th>
                        <th class="px-6 py-4 font-semibold">Status</th>
                        <th class="px-6 py-4 font-semibold">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-brand-border">
                    @foreach (var branch in Model)
                    {
                        <tr class="align-top transition-colors hover:bg-brand-light/50">
                            <td class="px-6 py-4">
                                @if (!string.IsNullOrWhiteSpace(branch.ThumbnailUrl))
                                {
                                    <img src="@branch.ThumbnailUrl" alt="@branch.Name" class="h-12 w-20 rounded-md border border-brand-border object-cover" />
                                }
                                else
                                {
                                    <div class="grid h-12 w-20 place-items-center rounded-md border border-brand-border bg-brand-light text-xs font-semibold text-brand-gray">
                                        No image
                                    </div>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <p class="font-semibold text-brand-dark">@branch.Name</p>
                                <p class="mt-1 text-xs text-brand-gray">/@branch.Slug</p>
                                <p class="mt-2 max-w-xs text-xs leading-5 text-brand-gray">@branch.Address, @branch.District</p>
                            </td>
                            <td class="px-6 py-4">@branch.City</td>
                            <td class="px-6 py-4">@branch.Hotline</td>
                            <td class="px-6 py-4">
                                @if (branch.IsActive)
                                {
                                    <span class="rounded-button border border-green-200 bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">Đang hiển thị</span>
                                }
                                else
                                {
                                    <span class="rounded-button border border-gray-200 bg-gray-100 px-3 py-1 text-xs font-semibold text-gray-600">Đã ẩn</span>
                                }
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-wrap gap-3">
                                    <a href="@Url.Action("Edit", new { id = branch.Id })" class="font-semibold text-brand-goldDeep transition hover:text-brand-dark">Sửa</a>
                                    <form asp-action="Delete" asp-route-id="@branch.Id" method="post" class="inline" onsubmit="return confirm('Ẩn chi nhánh này khỏi website công khai?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="font-semibold text-brand-redDark transition hover:text-brand-red">Xóa mềm</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="p-8 text-center text-brand-gray">
                Chưa có chi nhánh nào.
            </div>
        }
    </div>
</section>
